<script>
  import { onMount, onDestroy, tick } from 'svelte';
  import SlideRenderer from '../lib/SlideRenderer.svelte';
  
  // Panel Components (extracted for better organization)
  import SlidesPanel from './lib/panels/SlidesPanel.svelte';
  import LayersPanel from './lib/panels/LayersPanel.svelte';
  import HistoryPanel from './lib/panels/HistoryPanel.svelte';
  import PropertiesPanel from './lib/panels/PropertiesPanel.svelte';
  
  // Config Windows (floating, draggable)
  import WidgetConfigWindow from './lib/config-windows/WidgetConfigWindow.svelte';
  import TextConfigWindow from './lib/config-windows/TextConfigWindow.svelte';
  import QRConfigWindow from './lib/config-windows/QRConfigWindow.svelte';
  import NavConfigWindow from './lib/config-windows/NavConfigWindow.svelte';
  
  // Modals
  import MediaModal from './lib/modals/MediaModal.svelte';
  import WidgetModal from './lib/modals/WidgetModal.svelte';
  import KeyboardShortcutsModal from './lib/modals/KeyboardShortcutsModal.svelte';
  import VariablesModal from './lib/modals/VariablesModal.svelte';
  import AddGroupModal from './lib/modals/AddGroupModal.svelte';
  import DeleteConfirmModal from './lib/modals/DeleteConfirmModal.svelte';
  import UnsavedChangesModal from './lib/modals/UnsavedChangesModal.svelte';
  import SaveAsTemplateModal from './lib/modals/SaveAsTemplateModal.svelte';
  import SlideSettingsModal from './lib/modals/SlideSettingsModal.svelte';
  import GroupSettingsModal from './lib/modals/GroupSettingsModal.svelte';
  
  // Data files (moved out to reduce main file size)
  import { iconCategories, allIcons } from './lib/data/iconCategories.js';
  import { getMenuDefinitions } from './lib/data/menuDefinitions.js';

  // State
  let cast = null;
  let castId = null;
  let loading = true;
  let saving = false;
  let error = null;
  let hasUnsavedChanges = false;
  
  // Current group and slide
  let currentGroupId = 'home';
  let currentSlideIndex = 0;
  let selectedElementId = null;
  
  // Group management modal
  let showAddGroupModal = false;
  let newGroupName = '';
  
  // Settings modals
  let showSlideSettingsModal = false;
  let showGroupSettingsModal = false;
  let editingSlideIndex = null;
  
  // Slide drag reorder
  let draggedSlideIndex = null;
  let dragOverSlideIndex = null;
  
  // Layer drag reorder
  let draggedLayerId = null;
  let dragOverLayerId = null;
  
  // Slide clipboard (cut/copy/paste)
  let slideClipboard = null;
  let clipboardOperation = null; // 'cut' or 'copy'
  let showPasteSlideModal = false;
  
  // Available media and widgets
  let mediaLibrary = [];
  let onlineScreens = [];
  let availableWidgets = [];
  let widgetCategories = [];
  
  // Modals
  let showMediaModal = false;
  let showWidgetModal = false;
  let widgetSearchQuery = '';
  let selectedWidgetCategory = 'all';
  let showVariablesModal = false;
  let showPreviewModal = false;
  let showSaveAsTemplateModal = false;
  let templateName = '';
  let templateDescription = '';
  let savingTemplate = false;
  
  // Widget configuration window (floating, draggable)
  let showWidgetConfigModal = false;
  let widgetConfigElement = null;
  let widgetConfigPos = { x: 100, y: 100 };
  let isDraggingWidgetConfig = false;
  let widgetConfigDragOffset = { x: 0, y: 0 };
  
  // Text configuration window (floating, draggable)
  let showTextConfigModal = false;
  let textConfigElement = null;
  let textConfigPos = { x: 150, y: 120 };
  let isDraggingTextConfig = false;
  let textConfigDragOffset = { x: 0, y: 0 };
  
  // Nav configuration window (floating, draggable)
  let showNavConfigModal = false;
  let navConfigElement = null;
  let navConfigPos = { x: 100, y: 80 };
  let isDraggingNavConfig = false;
  let navConfigDragOffset = { x: 0, y: 0 };
  let navConfigTab = 'style'; // 'style' | 'appearance' | 'items'
  
  // QR configuration window (floating, draggable)
  let showQRConfigModal = false;
  let qrConfigElement = null;
  let qrConfigPos = { x: 200, y: 150 };
  let isDraggingQRConfig = false;
  let qrConfigDragOffset = { x: 0, y: 0 };
  
  // Confirmation modals
  let showUnsavedChangesModal = false;
  let pendingNavigation = null;
  let showDeleteLayerModal = false;
  let pendingDeleteLayerId = null;
  let showDeleteSlideModal = false;
  let pendingDeleteSlideIndex = null;
  let showDeleteGroupModal = false;
  let pendingDeleteGroupId = null;
  
  // Nav Icon Picker
  let showNavIconPicker = false;
  let navIconPickerItemIndex = null;
  let iconSearchQuery = '';
  let activeIconCategory = 'all';
  
  // Menu Bar State
  let openMenu = null;
  let showLayersPanel = true;
  let showPropertiesPanel = true;
  let showSlidesPanel = true;
  // History panel is off by default, toggle from View menu
  let showCanvasSizeModal = false;
  let showKeyboardShortcutsModal = false;
  
  // Right sidebar resize
  let rightSidebarWidth = 300;
  let rightSidebarCollapsed = false;
  let isResizingSidebar = false;
  let sidebarResizeStartX = 0;
  let sidebarResizeStartWidth = 0;
  const SIDEBAR_MIN_WIDTH = 260;
  const SIDEBAR_MAX_WIDTH = 500;
  
  // Menu definitions
  const menuDefinitions = {
    file: {
      label: 'File',
      items: [
        { label: 'New Cast', action: 'newCast', shortcut: null },
        { type: 'separator' },
        { label: 'Save', action: 'save', shortcut: '⌘S' },
        { label: 'Save as Template...', action: 'saveAsTemplate', shortcut: null },
        { type: 'separator' },
        { label: 'Export Cast...', action: 'exportCast', shortcut: null },
        { type: 'separator' },
        { label: 'Close', action: 'close', shortcut: null }
      ]
    },
    edit: {
      label: 'Edit',
      items: [
        { label: 'Undo', action: 'undo', shortcut: '⌘Z', disabled: () => historyIndex <= 0 },
        { label: 'Redo', action: 'redo', shortcut: '⌘⇧Z', disabled: () => historyIndex >= historyStack.length - 1 },
        { type: 'separator' },
        { label: 'Cut', action: 'cut', shortcut: '⌘X', disabled: () => !selectedElement },
        { label: 'Copy', action: 'copy', shortcut: '⌘C', disabled: () => !selectedElement },
        { label: 'Paste', action: 'paste', shortcut: '⌘V', disabled: () => !clipboardElement },
        { label: 'Duplicate', action: 'duplicate', shortcut: '⌘D', disabled: () => !selectedElement },
        { type: 'separator' },
        { label: 'Delete', action: 'delete', shortcut: '⌫', disabled: () => !selectedElement },
        { type: 'separator' },
        { label: 'Select All', action: 'selectAll', shortcut: '⌘A' }
      ]
    },
    view: {
      label: 'View',
      items: [
        { label: 'Zoom In', action: 'zoomIn', shortcut: '⌘+' },
        { label: 'Zoom Out', action: 'zoomOut', shortcut: '⌘-' },
        { label: 'Zoom to Fit', action: 'zoomFit', shortcut: '⌘0' },
        { type: 'separator' },
        { label: 'Show Slides Panel', action: 'toggleSlidesPanel', checked: () => showSlidesPanel },
        { label: 'Show Layers Panel', action: 'toggleLayersPanel', checked: () => showLayersPanel },
        { label: 'Show Properties Panel', action: 'togglePropertiesPanel', checked: () => showPropertiesPanel },
        { label: 'Show History Panel', action: 'toggleHistoryPanel', checked: () => showHistoryPanel }
      ]
    },
    insert: {
      label: 'Insert',
      items: [
        { label: 'Text', action: 'insertText', icon: 'fa-solid fa-font' },
        { label: 'Image...', action: 'insertImage', icon: 'fa-solid fa-image' },
        { label: 'Widget...', action: 'insertWidget', icon: 'fa-solid fa-puzzle-piece' },
        { type: 'separator' },
        { label: 'Shape', action: 'insertShape', icon: 'fa-solid fa-shapes', submenu: [
          { label: 'Rectangle', action: 'insertRectangle' },
          { label: 'Circle', action: 'insertCircle' }
        ]},
        { type: 'separator' },
        { label: 'QR Code', action: 'insertQrCode', icon: 'fa-solid fa-qrcode' },
        { label: 'Navigation', action: 'insertNav', icon: 'fa-solid fa-compass' },
        { label: 'Ping Button', action: 'insertPing', icon: 'fa-solid fa-bell' }
      ]
    },
    arrange: {
      label: 'Arrange',
      items: [
        { label: 'Bring to Front', action: 'bringToFront', shortcut: '⌘⇧]', disabled: () => !selectedElement },
        { label: 'Bring Forward', action: 'bringForward', shortcut: '⌘]', disabled: () => !selectedElement },
        { label: 'Send Backward', action: 'sendBackward', shortcut: '⌘[', disabled: () => !selectedElement },
        { label: 'Send to Back', action: 'sendToBack', shortcut: '⌘⇧[', disabled: () => !selectedElement },
        { type: 'separator' },
        { label: 'Align', submenu: [
          { label: 'Align Left', action: 'alignLeft', disabled: () => !selectedElement },
          { label: 'Align Center', action: 'alignCenter', disabled: () => !selectedElement },
          { label: 'Align Right', action: 'alignRight', disabled: () => !selectedElement },
          { type: 'separator' },
          { label: 'Align Top', action: 'alignTop', disabled: () => !selectedElement },
          { label: 'Align Middle', action: 'alignMiddle', disabled: () => !selectedElement },
          { label: 'Align Bottom', action: 'alignBottom', disabled: () => !selectedElement }
        ]}
      ]
    },
    cast: {
      label: 'Cast',
      items: [
        { label: 'Canvas Size...', action: 'canvasSize', icon: 'fa-solid fa-expand' },
        { label: 'Background...', action: 'background', icon: 'fa-solid fa-fill-drip' },
        { type: 'separator' },
        { label: 'Variables...', action: 'variables', icon: 'fa-solid fa-code' },
        { label: 'Groups...', action: 'groups', icon: 'fa-solid fa-layer-group' },
        { type: 'separator' },
        { label: 'Slide Timing...', action: 'slideTiming', icon: 'fa-solid fa-clock' }
      ]
    },
    help: {
      label: 'Help',
      items: [
        { label: 'Keyboard Shortcuts', action: 'keyboardShortcuts', shortcut: '⌘?' },
        { label: 'Documentation', action: 'documentation', icon: 'fa-solid fa-book' }
      ]
    }
  };
  
  // Icon categories and allIcons are now imported from ./lib/data/iconCategories.js
  // (Saves ~370 lines in this file)
  
  // Reactive filtered icons
  $: filteredNavIcons = iconSearchQuery 
    ? allIcons.filter(icon => 
        icon.name.toLowerCase().includes(iconSearchQuery.toLowerCase()) ||
        icon.category.toLowerCase().includes(iconSearchQuery.toLowerCase())
      )
    : activeIconCategory === 'all' 
      ? allIcons 
      : iconCategories.find(c => c.name === activeIconCategory)?.icons || [];
  
  // URL import
  let importUrl = '';
  let importingUrl = false;
  
  // Media upload
  let mediaFileInput = null;
  let isDraggingMedia = false;
  let uploadingMedia = false;
  
  // Canvas zoom and pan
  let canvasZoom = 0.5;
  let canvasPan = { x: 0, y: 0 };
  let canvasContainer = null;
  let isPanning = false;
  let panStart = { x: 0, y: 0, panX: 0, panY: 0 };
  let canvasNeedsScroll = false;
  
  // Tool mode: 'pointer' (default selection) or 'hand' (pan mode)
  let activeTool = 'pointer';
  
  // Check if canvas needs scrollbars (scaled canvas larger than container)
  $: if (canvasContainer && typeof window !== 'undefined') {
    const scaledWidth = 1920 * canvasZoom;
    const scaledHeight = 1080 * canvasZoom;
    const containerWidth = canvasContainer.clientWidth;
    const containerHeight = canvasContainer.clientHeight;
    canvasNeedsScroll = scaledWidth > containerWidth || scaledHeight > containerHeight;
  }
  
  // Panels
  let slidesPanelCollapsed = false;
  let propertiesPanelCollapsed = false;
  let layersPanelCollapsed = false;
  let historyPanelCollapsed = false;
  
  // Drag state
  let isDragging = false;
  let isResizing = false;
  let dragStart = { x: 0, y: 0 };
  let resizeHandle = null;
  let originalElement = null;
  
  // Undo/Redo history with action descriptions
  let historyStack = []; // Array of { state: string, action: string, timestamp: Date }
  let historyIndex = -1;
  const MAX_HISTORY = 100;
  let showHistoryPanel = false;
  
  // Platform detection for keyboard shortcuts display
  let isMac = false;
  $: modKey = isMac ? '⌘' : 'Ctrl';
  
  // Initialize history WITHOUT marking as changed (for loading casts)
  function initHistory() {
    if (!cast) return;
    historyStack = [{
      state: JSON.stringify(cast),
      action: 'Opened cast',
      timestamp: new Date()
    }];
    historyIndex = 0;
    hasUnsavedChanges = false;
  }
  
  // Push to history AND mark as changed (for user edits)
  function pushHistory(action = 'Change') {
    if (!cast) return;
    
    // Check if state actually changed (skip duplicate pushes)
    const currentState = JSON.stringify(cast);
    if (historyIndex >= 0 && historyStack[historyIndex]?.state === currentState) {
      return; // No actual change, skip
    }
    
    // Remove any redo states
    historyStack = historyStack.slice(0, historyIndex + 1);
    // Add current state with action description
    historyStack.push({
      state: currentState,
      action: action,
      timestamp: new Date()
    });
    // Trim if too long
    if (historyStack.length > MAX_HISTORY) {
      historyStack.shift();
    }
    historyIndex = historyStack.length - 1;
    hasUnsavedChanges = true;
  }
  
  function undo() {
    if (historyIndex > 0) {
      historyIndex--;
      cast = JSON.parse(historyStack[historyIndex].state);
    }
  }
  
  function redo() {
    if (historyIndex < historyStack.length - 1) {
      historyIndex++;
      cast = JSON.parse(historyStack[historyIndex].state);
    }
  }
  
  function jumpToHistory(index) {
    if (index >= 0 && index < historyStack.length) {
      historyIndex = index;
      cast = JSON.parse(historyStack[historyIndex].state);
    }
  }
  
  function formatHistoryTime(date) {
    return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }
  
  // Debounced property change handler - batches rapid style/property changes
  let propertyChangeTimer = null;
  let pendingPropertyAction = null;
  
  function trackPropertyChange(action) {
    // Clear existing timer
    if (propertyChangeTimer) {
      clearTimeout(propertyChangeTimer);
    }
    
    // Store the latest action
    pendingPropertyAction = action;
    
    // Schedule history push after 500ms of no changes
    propertyChangeTimer = setTimeout(() => {
      if (pendingPropertyAction) {
        pushHistory(pendingPropertyAction);
        pendingPropertyAction = null;
      }
    }, 500);
  }
  
  // Helper for element property changes
  function onElementChange(property) {
    cast = cast;
    const name = selectedElement?.name || selectedElement?.type || 'element';
    trackPropertyChange(`Change "${name}" ${property}`);
    // Auto-run widget when any property changes
    scheduleWidgetAutoRun(selectedElement);
  }
  
  // Helper for slide property changes
  function onSlideChange(property) {
    cast = { ...cast };
    const slide = currentSlides?.[editingSlideIndex];
    const name = slide?.name || `Slide ${editingSlideIndex + 1}`;
    trackPropertyChange(`Change "${name}" ${property}`);
  }
  
  // Helper for group property changes
  function onGroupChange(property) {
    cast = { ...cast };
    const name = currentGroup?.name || 'group';
    trackPropertyChange(`Change "${name}" ${property}`);
  }

  // Navigation with unsaved changes check
  function goto(path) {
    if (hasUnsavedChanges) {
      pendingNavigation = path;
      showUnsavedChangesModal = true;
    } else {
      window.location.href = path;
    }
  }
  
  function confirmNavigateAway() {
    showUnsavedChangesModal = false;
    hasUnsavedChanges = false;
    if (pendingNavigation === 'reload') {
      window.location.reload();
    } else if (pendingNavigation === 'back') {
      // Go back twice: once to undo our pushState, once for actual back
      history.go(-2);
    } else if (pendingNavigation) {
      window.location.href = pendingNavigation;
    }
  }
  
  async function saveAndNavigate() {
    await saveCast();
    showUnsavedChangesModal = false;
    hasUnsavedChanges = false;
    if (pendingNavigation === 'reload') {
      window.location.reload();
    } else if (pendingNavigation === 'back') {
      history.go(-2);
    } else if (pendingNavigation) {
      window.location.href = pendingNavigation;
    }
  }
  
  function cancelNavigation() {
    showUnsavedChangesModal = false;
    pendingNavigation = null;
  }

  function getQueryParam(name) {
    const params = new URLSearchParams(window.location.search);
    return params.get(name);
  }

  // Fast tooltip system - uses fixed positioning to avoid overflow clipping
  let tooltipElement = null;
  let tooltipShowTimeout = null;
  let tooltipHideTimeout = null;
  let currentTooltipTarget = null;
  
  function createTooltipElement() {
    if (tooltipElement) return tooltipElement;
    tooltipElement = document.createElement('div');
    tooltipElement.className = 'fast-tooltip';
    tooltipElement.style.cssText = `
      position: fixed;
      padding: 0.4rem 0.65rem;
      background: rgba(15, 15, 20, 0.95);
      color: white;
      font-size: 0.75rem;
      font-weight: 500;
      white-space: nowrap;
      border-radius: 5px;
      pointer-events: none;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.12s ease;
      z-index: 100000;
      border: 1px solid rgb(var(--color-border));
    `;
    document.body.appendChild(tooltipElement);
    return tooltipElement;
  }
  
  function showTooltip(el) {
    if (!el || el !== currentTooltipTarget) return;
    
    const tooltip = el.getAttribute('data-tooltip');
    if (!tooltip) return;
    
    const tip = createTooltipElement();
    tip.textContent = tooltip;
    
    // Make visible briefly to measure
    tip.style.visibility = 'hidden';
    tip.style.opacity = '0';
    tip.style.display = 'block';
    
    const rect = el.getBoundingClientRect();
    const tipRect = tip.getBoundingClientRect();
    
    // Position above by default
    let top = rect.top - tipRect.height - 6;
    let left = rect.left + (rect.width / 2) - (tipRect.width / 2);
    
    // If would go off top, show below instead
    if (top < 5) {
      top = rect.bottom + 6;
    }
    
    // Keep within horizontal bounds
    if (left < 5) left = 5;
    if (left + tipRect.width > window.innerWidth - 5) {
      left = window.innerWidth - tipRect.width - 5;
    }
    
    tip.style.top = `${top}px`;
    tip.style.left = `${left}px`;
    tip.style.visibility = 'visible';
    tip.style.opacity = '1';
  }
  
  function hideTooltip() {
    if (tooltipElement) {
      tooltipElement.style.opacity = '0';
      tooltipElement.style.visibility = 'hidden';
    }
  }
  
  function handleTooltipMouseOver(e) {
    const el = e.target.closest('[data-tooltip]');
    
    // Clear any pending hide
    clearTimeout(tooltipHideTimeout);
    
    if (!el) {
      // Mouse moved to non-tooltip element, schedule hide
      tooltipHideTimeout = setTimeout(() => {
        currentTooltipTarget = null;
        hideTooltip();
      }, 50);
      return;
    }
    
    // Same element, keep showing
    if (el === currentTooltipTarget) return;
    
    // New element - update immediately if we already have a tooltip showing
    clearTimeout(tooltipShowTimeout);
    currentTooltipTarget = el;
    
    if (tooltipElement && tooltipElement.style.opacity === '1') {
      // Already showing a tooltip, switch instantly
      showTooltip(el);
    } else {
      // No tooltip showing, use short delay
      tooltipShowTimeout = setTimeout(() => showTooltip(el), 80);
    }
  }
  
  function handleTooltipMouseOut(e) {
    // Only hide if we're leaving to something without a tooltip
    const relatedTarget = e.relatedTarget;
    const newTooltipEl = relatedTarget?.closest?.('[data-tooltip]');
    
    if (!newTooltipEl) {
      clearTimeout(tooltipShowTimeout);
      tooltipHideTimeout = setTimeout(() => {
        currentTooltipTarget = null;
        hideTooltip();
      }, 100);
    }
  }

  // Convert title attributes to data-tooltip for fast tooltips
  function convertTitlesToTooltips(container = document) {
    container.querySelectorAll('[title]').forEach(el => {
      const title = el.getAttribute('title');
      if (title) {
        el.setAttribute('data-tooltip', title);
        el.removeAttribute('title');
      }
    });
  }

  // Dynamic CSS loading
  let studioStyleElement = null;
  
  async function loadStudioStyles() {
    try {
      const response = await fetch('/api/extensions/slidecast/static/studio.css');
      if (response.ok) {
        const css = await response.text();
        studioStyleElement = document.createElement('style');
        studioStyleElement.id = 'slidecast-studio-styles';
        studioStyleElement.textContent = css;
        document.head.appendChild(studioStyleElement);
      }
    } catch (e) {
      console.warn('Failed to load studio styles:', e);
    }
  }

  onMount(async () => {
    // Load external CSS
    await loadStudioStyles();
    
    // Detect Mac for keyboard shortcut display
    isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0 || 
            navigator.userAgent.toUpperCase().indexOf('MAC') >= 0;
    
    // Convert existing titles to fast tooltips
    setTimeout(() => convertTitlesToTooltips(), 100);
    
    // Add tooltip event listeners (using mouseover/mouseout for better bubbling)
    document.addEventListener('mouseover', handleTooltipMouseOver, true);
    document.addEventListener('mouseout', handleTooltipMouseOut, true);
    
    // Watch for new elements with title attributes
    tooltipObserver = new MutationObserver((mutations) => {
      mutations.forEach(mutation => {
        mutation.addedNodes.forEach(node => {
          if (node.nodeType === 1) {
            convertTitlesToTooltips(node);
            if (node.hasAttribute?.('title')) {
              const title = node.getAttribute('title');
              node.setAttribute('data-tooltip', title);
              node.removeAttribute('title');
            }
          }
        });
      });
    });
    tooltipObserver.observe(document.body, { childList: true, subtree: true });
    
    castId = getQueryParam('id');
    
    await Promise.all([
      loadCast(),
      loadWidgets(),
      loadMedia(),
      loadScreens()
    ]);
    
    loading = false;
    
    // Initial zoom
    await tick();
    zoomFit();
    
    // Auto-run all widgets on the current slide
    await runAllWidgetsOnSlide();
    
    // Event listeners
    document.addEventListener('paste', handlePaste);
    document.addEventListener('keydown', handleKeyboard);
    document.addEventListener('keydown', handleRefreshIntercept);
    document.addEventListener('click', handleLinkClick, true); // Capture phase to intercept all link clicks
    document.addEventListener('click', handleClickOutside);
    window.addEventListener('resize', handleResize);
    window.addEventListener('popstate', handlePopState);
    window.addEventListener('beforeunload', handleBeforeUnload);
    
    // Push initial state so we can intercept back button
    if (typeof window !== 'undefined') {
      history.pushState({ slidecastStudio: true }, '');
    }
  });
  
  // Intercept browser back/forward buttons
  function handlePopState(e) {
    if (hasUnsavedChanges) {
      // Push state back to prevent navigation, then show modal
      history.pushState({ slidecastStudio: true }, '');
      pendingNavigation = 'back';
      showUnsavedChangesModal = true;
    } else {
      // No unsaved changes, allow normal back navigation
      history.back();
    }
  }
  
  // Only for tab close - shows Chrome's native dialog
  function handleBeforeUnload(e) {
    if (hasUnsavedChanges) {
      e.preventDefault();
      e.returnValue = 'You have unsaved changes.';
      return e.returnValue;
    }
  }
  
  // Intercept browser refresh shortcuts (Cmd+R, Ctrl+R, F5) to show our modal
  function handleRefreshIntercept(e) {
    // F5 or Cmd/Ctrl+R
    const isRefresh = e.key === 'F5' || ((e.metaKey || e.ctrlKey) && e.key === 'r');
    if (isRefresh && hasUnsavedChanges) {
      e.preventDefault();
      pendingNavigation = 'reload';
      showUnsavedChangesModal = true;
    }
  }
  
  // Intercept all link clicks to check for unsaved changes
  function handleLinkClick(e) {
    // Find if click was on or inside an <a> tag
    const link = e.target.closest('a');
    if (!link) return;
    
    const href = link.getAttribute('href');
    // Skip if no href, javascript:, or # links
    if (!href || href.startsWith('javascript:') || href === '#') return;
    
    // Skip if it's the same page
    if (href === window.location.pathname + window.location.search) return;
    
    // If we have unsaved changes, show our modal instead of navigating
    if (hasUnsavedChanges) {
      e.preventDefault();
      e.stopPropagation();
      pendingNavigation = href;
      showUnsavedChangesModal = true;
    }
  }

  onDestroy(() => {
    // Remove dynamically loaded styles
    if (studioStyleElement && studioStyleElement.parentNode) {
      studioStyleElement.parentNode.removeChild(studioStyleElement);
    }
    
    document.removeEventListener('paste', handlePaste);
    document.removeEventListener('keydown', handleKeyboard);
    document.removeEventListener('keydown', handleRefreshIntercept);
    document.removeEventListener('click', handleLinkClick, true);
    document.removeEventListener('click', handleClickOutside);
    window.removeEventListener('resize', handleResize);
    window.removeEventListener('popstate', handlePopState);
    window.removeEventListener('beforeunload', handleBeforeUnload);
    // Cleanup tooltip system
    if (tooltipObserver) {
      tooltipObserver.disconnect();
    }
    document.removeEventListener('mouseover', handleTooltipMouseOver, true);
    document.removeEventListener('mouseout', handleTooltipMouseOut, true);
    if (tooltipElement && tooltipElement.parentNode) {
      tooltipElement.parentNode.removeChild(tooltipElement);
    }
    clearTimeout(tooltipShowTimeout);
    clearTimeout(tooltipHideTimeout);
    // Clear widget auto-run timer
    if (widgetAutoRunTimer) {
      clearTimeout(widgetAutoRunTimer);
    }
    // Clear property change timer
    if (propertyChangeTimer) {
      clearTimeout(propertyChangeTimer);
    }
  });

  // Data loading
  async function loadCast() {
    if (!castId || castId === 'new') {
      cast = createNewCast();
      initHistory(); // Initialize history for new cast (no unsaved changes yet)
        return;
      }
      
    try {
      const response = await fetch(`/api/extensions/slidecast/casts/${castId}`);
      const data = await response.json();
      if (data.success) {
        cast = migrateCastToGroups(data.cast);
        // Ensure definition structure
        if (!cast.definition) {
          cast.definition = { settings: {}, variables: {}, groups: [] };
        }
        // Set initial group
        const defaultGroup = cast.definition.groups?.find(g => g.isDefault) || cast.definition.groups?.[0];
        currentGroupId = defaultGroup?.id || 'home';
        currentSlideIndex = 0;
        // Initialize history with loaded state (no unsaved changes yet)
        initHistory();
      } else {
        error = 'Cast not found';
      }
    } catch (err) {
      error = err.message;
    }
  }

  function createNewCast() {
    const bgId = generateId();
    return {
      name: 'Untitled Cast',
      definition: {
        settings: {
          resolution: { width: 1920, height: 1080 },
          transition: { type: 'fade', duration: 1000 },
          backgroundColor: '#1a1a2e'
        },
        variables: {},
        groups: [{
          id: 'home',
          name: 'Home',
          isDefault: true,
          loop: true,
          defaultDuration: 10000,
          slides: [{
            id: generateId(),
            name: 'Slide',
            duration: 10000,
            backgroundColor: '#1a1a2e',
            elements: [
              {
                id: bgId,
                type: 'background',
                name: 'Background',
                locked: true,
                position: { x: 0, y: 0 },
                size: { width: 1920, height: 1080 },
                zIndex: 0,
                style: { backgroundColor: '#1a1a2e' }
              }
            ]
          }]
        }]
      }
    };
  }
  
  // Migrate legacy casts to groups structure
  function migrateCastToGroups(castData) {
    if (!castData?.definition) return castData;
    
    // Already has groups
    if (castData.definition.groups) return castData;
    
    // Has legacy slides array - wrap in Home group
    if (castData.definition.slides) {
      castData.definition = {
        settings: {
          resolution: castData.definition.settings?.resolution || { width: 1920, height: 1080 },
          transition: castData.definition.settings?.transition || { type: 'fade', duration: 500 },
          backgroundColor: castData.definition.settings?.backgroundColor || '#000000'
        },
        variables: castData.definition.variables || {},
        groups: [{
          id: 'home',
          name: 'Home',
          isDefault: true,
          loop: castData.definition.settings?.loop !== false,
          defaultDuration: castData.definition.settings?.defaultDuration || 10000,
          slides: castData.definition.slides
        }]
      };
    }
    
    return castData;
  }

  async function loadWidgets() {
    try {
      const [widgetsRes, categoriesRes] = await Promise.all([
        fetch('/api/extensions/slidecast/widgets?published=true'),
        fetch('/api/extensions/slidecast/widgets/meta/categories')
      ]);
      const widgetsData = await widgetsRes.json();
      const categoriesData = await categoriesRes.json();
      availableWidgets = widgetsData.widgets || [];
      widgetCategories = categoriesData.categories || [];
    } catch (err) {
      console.error('Failed to load widgets:', err);
    }
  }

  // Run a widget to execute its code and render on canvas
  let runningWidgetId = null;
  let widgetAutoRunTimer = null;
  let tooltipObserver = null;
  
  // Track widgets that have been loading for > 500ms (show spinner below widget)
  let slowLoadingWidgets = new Set();
  let widgetLoadingTimers = {};
  
  // Debounced auto-run when widget properties change
  function scheduleWidgetAutoRun(element) {
    if (!element || element.type !== 'widget') return;
    
    // Clear any pending auto-run
    if (widgetAutoRunTimer) {
      clearTimeout(widgetAutoRunTimer);
    }
    
    // Schedule a new run after 300ms of no changes
    widgetAutoRunTimer = setTimeout(() => {
      runWidget(element);
    }, 300);
  }
  
  // Open widget configuration window
  function openWidgetConfig(element) {
    if (!element || element.type !== 'widget') return;
    widgetConfigElement = element;
    // Position window to the right of the widget, or center if not enough space
    const windowWidth = 520;
    const windowHeight = 500;
    const margin = 20;
    let x = element.position.x + element.size.width + margin;
    let y = element.position.y;
    // Adjust if would go off screen
    if (x + windowWidth > window.innerWidth - 300) { // 300 for right panel
      x = Math.max(margin, element.position.x - windowWidth - margin);
    }
    if (y + windowHeight > window.innerHeight - 100) {
      y = Math.max(margin, window.innerHeight - windowHeight - 100);
    }
    widgetConfigPos = { x: Math.max(200, x), y: Math.max(60, y) };
    showWidgetConfigModal = true;
  }
  
  // Close widget config window and auto-run
  function closeWidgetConfig() {
    if (widgetConfigElement) {
      runWidget(widgetConfigElement);
    }
    showWidgetConfigModal = false;
    widgetConfigElement = null;
  }
  
  // Widget config window drag handlers
  function startWidgetConfigDrag(e) {
    if (e.target.closest('input, select, button, a, .toggle-switch')) return;
    isDraggingWidgetConfig = true;
    widgetConfigDragOffset = {
      x: e.clientX - widgetConfigPos.x,
      y: e.clientY - widgetConfigPos.y
    };
    window.addEventListener('mousemove', dragWidgetConfig);
    window.addEventListener('mouseup', stopWidgetConfigDrag);
  }
  
  function dragWidgetConfig(e) {
    if (!isDraggingWidgetConfig) return;
    widgetConfigPos = {
      x: Math.max(0, Math.min(window.innerWidth - 520, e.clientX - widgetConfigDragOffset.x)),
      y: Math.max(0, Math.min(window.innerHeight - 100, e.clientY - widgetConfigDragOffset.y))
    };
  }
  
  function stopWidgetConfigDrag() {
    isDraggingWidgetConfig = false;
    window.removeEventListener('mousemove', dragWidgetConfig);
    window.removeEventListener('mouseup', stopWidgetConfigDrag);
  }
  
  // Open text configuration window
  function openTextConfig(element) {
    if (!element || element.type !== 'text') return;
    textConfigElement = element;
    // Position window to the right of the text, or center if not enough space
    const windowWidth = 420;
    const windowHeight = 500;
    const margin = 20;
    let x = element.position.x + element.size.width + margin;
    let y = element.position.y;
    // Adjust if would go off screen
    if (x + windowWidth > window.innerWidth - 300) {
      x = Math.max(margin, element.position.x - windowWidth - margin);
    }
    if (y + windowHeight > window.innerHeight - 100) {
      y = Math.max(margin, window.innerHeight - windowHeight - 100);
    }
    textConfigPos = { x: Math.max(200, x), y: Math.max(60, y) };
    showTextConfigModal = true;
  }
  
  // Close text config window
  function closeTextConfig() {
    showTextConfigModal = false;
    textConfigElement = null;
  }
  
  // Text config window drag handlers
  function startTextConfigDrag(e) {
    if (e.target.closest('input, select, button, textarea, .toggle-switch')) return;
    isDraggingTextConfig = true;
    textConfigDragOffset = {
      x: e.clientX - textConfigPos.x,
      y: e.clientY - textConfigPos.y
    };
    window.addEventListener('mousemove', dragTextConfig);
    window.addEventListener('mouseup', stopTextConfigDrag);
  }
  
  function dragTextConfig(e) {
    if (!isDraggingTextConfig) return;
    textConfigPos = {
      x: Math.max(0, Math.min(window.innerWidth - 420, e.clientX - textConfigDragOffset.x)),
      y: Math.max(0, Math.min(window.innerHeight - 100, e.clientY - textConfigDragOffset.y))
    };
  }
  
  function stopTextConfigDrag() {
    isDraggingTextConfig = false;
    window.removeEventListener('mousemove', dragTextConfig);
    window.removeEventListener('mouseup', stopTextConfigDrag);
  }
  
  // Open Nav configuration window
  function openNavConfig(element) {
    if (!element || element.type !== 'nav') return;
    navConfigElement = element;
    const windowWidth = 520;
    const margin = 20;
    let x = element.position.x + element.size.width + margin;
    if (x + windowWidth > window.innerWidth - 100) {
      x = element.position.x - windowWidth - margin;
    }
    if (x < margin) x = margin;
    let y = Math.max(margin, Math.min(element.position.y, window.innerHeight - 500));
    navConfigPos = { x, y };
    showNavConfigModal = true;
  }
  
  function closeNavConfig() {
    showNavConfigModal = false;
    navConfigElement = null;
  }
  
  function startNavConfigDrag(e) {
    if (e.target.closest('input, select, button, textarea, .toggle-switch')) return;
    isDraggingNavConfig = true;
    navConfigDragOffset = {
      x: e.clientX - navConfigPos.x,
      y: e.clientY - navConfigPos.y
    };
    window.addEventListener('mousemove', dragNavConfig);
    window.addEventListener('mouseup', stopNavConfigDrag);
  }
  
  function dragNavConfig(e) {
    if (!isDraggingNavConfig) return;
    navConfigPos = {
      x: e.clientX - navConfigDragOffset.x,
      y: e.clientY - navConfigDragOffset.y
    };
  }
  
  function stopNavConfigDrag() {
    isDraggingNavConfig = false;
    window.removeEventListener('mousemove', dragNavConfig);
    window.removeEventListener('mouseup', stopNavConfigDrag);
  }
  
  // Open QR configuration window
  function openQRConfig(element) {
    if (!element || element.type !== 'qrcode') return;
    qrConfigElement = element;
    const windowWidth = 380;
    const margin = 20;
    let x = element.position.x + element.size.width + margin;
    if (x + windowWidth > window.innerWidth - 100) {
      x = element.position.x - windowWidth - margin;
    }
    if (x < margin) x = margin;
    let y = Math.max(margin, Math.min(element.position.y, window.innerHeight - 400));
    qrConfigPos = { x, y };
    showQRConfigModal = true;
  }
  
  function closeQRConfig() {
    showQRConfigModal = false;
    qrConfigElement = null;
  }
  
  function startQRConfigDrag(e) {
    if (e.target.closest('input, select, button, textarea')) return;
    isDraggingQRConfig = true;
    qrConfigDragOffset = {
      x: e.clientX - qrConfigPos.x,
      y: e.clientY - qrConfigPos.y
    };
    window.addEventListener('mousemove', dragQRConfig);
    window.addEventListener('mouseup', stopQRConfigDrag);
  }
  
  function dragQRConfig(e) {
    if (!isDraggingQRConfig) return;
    qrConfigPos = {
      x: e.clientX - qrConfigDragOffset.x,
      y: e.clientY - qrConfigDragOffset.y
    };
  }
  
  function stopQRConfigDrag() {
    isDraggingQRConfig = false;
    window.removeEventListener('mousemove', dragQRConfig);
    window.removeEventListener('mouseup', stopQRConfigDrag);
  }
  
  // Run all widgets on the current slide (called on cast load)
  async function runAllWidgetsOnSlide() {
    const slide = getCurrentSlide();
    if (!slide?.elements) return;
    
    const widgetElements = slide.elements.filter(el => el.type === 'widget' && el.widgetUuid);
    
    // Run all widgets in parallel
    await Promise.all(widgetElements.map(el => runWidget(el)));
  }
  
  async function runWidget(element) {
    if (!element || element.type !== 'widget' || !element.widgetUuid) return;
    
    runningWidgetId = element.id;
    element._widgetLoading = true;
    element._widgetError = null;
    cast = { ...cast }; // Trigger reactivity
    
    // Clear any existing timer for this widget
    if (widgetLoadingTimers[element.id]) {
      clearTimeout(widgetLoadingTimers[element.id]);
    }
    
    // Set timer to show spinner below widget after 500ms
    widgetLoadingTimers[element.id] = setTimeout(() => {
      slowLoadingWidgets.add(element.id);
      slowLoadingWidgets = new Set(slowLoadingWidgets); // Trigger reactivity
    }, 500);
    
    try {
      const response = await fetch(`/api/extensions/slidecast/protocol/widget/${element.widgetUuid}/render`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          config: element.widgetConfig || {},
          styles: element.widgetStyles || {},
          size: element.size
        })
      });
      const result = await response.json();
      
      if (result.success) {
        element._widgetRenderMode = result.renderMode;
        element._widgetPrimitives = result.primitives;
        element._widgetImageUrl = result.imageUrl;
        element._widgetError = null;
      } else {
        element._widgetError = result.error || 'Widget execution failed';
      }
    } catch (err) {
      element._widgetError = `Network error: ${err.message}`;
    } finally {
      // Clear the slow loading timer and state
      if (widgetLoadingTimers[element.id]) {
        clearTimeout(widgetLoadingTimers[element.id]);
        delete widgetLoadingTimers[element.id];
      }
      slowLoadingWidgets.delete(element.id);
      slowLoadingWidgets = new Set(slowLoadingWidgets); // Trigger reactivity
      
      element._widgetLoading = false;
      runningWidgetId = null;
      cast = { ...cast }; // Trigger reactivity
    }
  }

  async function loadMedia() {
    try {
      const response = await fetch('/api/extensions/slidecast/media');
      const data = await response.json();
      mediaLibrary = data.media || [];
    } catch (err) {
      console.error('Failed to load media:', err);
    }
  }

  async function loadScreens() {
    try {
      const response = await fetch('/api/extensions/slidecast/screens');
      const data = await response.json();
      onlineScreens = (data.screens || []).filter(s => s.status === 'online');
    } catch (err) {
      console.error('Failed to load screens:', err);
    }
  }

  // Helpers
  function generateId() {
    return 'el-' + Math.random().toString(36).substr(2, 9);
  }

  // Get current group object
  function getCurrentGroup() {
    return cast?.definition?.groups?.find(g => g.id === currentGroupId);
  }
  
  // Get slides for current group
  function getCurrentSlides() {
    return getCurrentGroup()?.slides || [];
  }

  function getCurrentSlide() {
    return getCurrentSlides()[currentSlideIndex];
  }

  function getSelectedElement() {
    if (!selectedElementId) return null;
    const slide = getCurrentSlide();
    return slide?.elements?.find(el => el.id === selectedElementId);
  }

  // Update background color for a specific slide (both slide property and background element)
  function updateSlideBackgroundColor(slide, color) {
    if (!slide) return;
    // Update slide's backgroundColor property (used by SlideRenderer's main background)
    slide.backgroundColor = color;
    // Also update the background element if it exists
    if (slide.elements) {
      const bgElement = slide.elements.find(el => el.type === 'background');
      if (bgElement && bgElement.style) {
        bgElement.style.backgroundColor = color;
      }
    }
  }

  // Update background for all slides using default in a group
  // Only updates slides that don't have a custom backgroundColor override
  function updateGroupDefaultBackgrounds(group, defaultColor) {
    if (!group?.slides) return;
    for (const slide of group.slides) {
      // Only update slides that are using the default (no custom backgroundColor set)
      if (!slide._hasCustomBackground) {
        updateSlideBackgroundColor(slide, defaultColor);
      }
    }
  }
  
  // Update a slide's background element only (without setting the slide's backgroundColor)
  function updateSlideBackgroundElement(slide, color) {
    if (!slide?.elements) return;
    const bgElement = slide.elements.find(el => el.type === 'background');
    if (bgElement && bgElement.style) {
      bgElement.style.backgroundColor = color;
    }
  }

  // Get effective background color for a slide (slide override or group default)
  function getEffectiveBackgroundColor(slide, group) {
    return slide?.backgroundColor || group?.defaultBackgroundColor || '#1a1a2e';
  }

  // Reactive statements
  $: currentGroup = cast?.definition?.groups?.find(g => g.id === currentGroupId);
  $: currentSlides = currentGroup?.slides || [];
  $: currentSlide = currentSlides[currentSlideIndex];
  $: selectedElement = selectedElementId ? currentSlide?.elements?.find(el => el.id === selectedElementId) : null;

  // Ensure widget defaults are filled in when selecting a widget element
  $: if (selectedElement?.type === 'widget' && availableWidgets.length > 0) {
    ensureWidgetDefaults(selectedElement);
  }

  // Fill in missing widget config/style defaults from the widget schema
  function ensureWidgetDefaults(element) {
    if (!element || element.type !== 'widget') return;
    
    const widget = availableWidgets.find(w => w.uuid === element.widgetUuid);
    if (!widget) return;
    
    let needsUpdate = false;
    
    // Ensure widgetConfig exists
    if (!element.widgetConfig) {
      element.widgetConfig = {};
      needsUpdate = true;
    }
    
    // Fill in missing config defaults
    if (widget.configSchema) {
      for (const [key, schema] of Object.entries(widget.configSchema)) {
        if (element.widgetConfig[key] === undefined && schema.default !== undefined) {
          element.widgetConfig[key] = schema.default;
          needsUpdate = true;
        }
      }
    }
    
    // Ensure widgetStyles exists
    if (!element.widgetStyles) {
      element.widgetStyles = {};
      needsUpdate = true;
    }
    
    // Fill in missing style defaults
    if (widget.styleSchema) {
      for (const [key, schema] of Object.entries(widget.styleSchema)) {
        if (element.widgetStyles[key] === undefined && schema.default !== undefined) {
          element.widgetStyles[key] = schema.default;
          needsUpdate = true;
        }
      }
    }
    
    // Sync size with config width/height if present
    if (element.widgetConfig.width && element.size.width !== element.widgetConfig.width) {
      element.size.width = element.widgetConfig.width;
      needsUpdate = true;
    }
    if (element.widgetConfig.height && element.size.height !== element.widgetConfig.height) {
      element.size.height = element.widgetConfig.height;
      needsUpdate = true;
    }
    
    if (needsUpdate) {
      cast = { ...cast }; // Trigger reactivity
    }
  }

  // Auto-sync ALL scoped nav changes when editing
  let lastNavSyncHash = '';
  $: if (selectedElement?.type === 'nav' && selectedElement.scope !== 'slide' && !selectedElement._isInheritedCopy) {
    // Create a hash of ALL nav properties to detect any changes
    const navHash = JSON.stringify({
      position: selectedElement.position,
      size: selectedElement.size,
      style: selectedElement.style,
      items: selectedElement.items,
      layout: selectedElement.layout,
      name: selectedElement.name
    });
    if (navHash !== lastNavSyncHash) {
      lastNavSyncHash = navHash;
      // Defer sync to avoid infinite loops
      setTimeout(() => syncNavChanges(selectedElement), 0);
    }
  }

  // Zoom controls
  function zoomIn() {
    canvasZoom = Math.min(canvasZoom + 0.1, 2);
  }

  function zoomOut() {
    canvasZoom = Math.max(canvasZoom - 0.1, 0.1);
  }

  function zoomFit() {
    if (!canvasContainer) return;
    const rect = canvasContainer.getBoundingClientRect();
    // TV Frame dimensions (from CSS):
    // - Bezel: padding 16px top, 16px sides, 28px bottom
    // - Stand: neck 16px + base 6px = 22px
    // Total: width = 1920+32 = 1952, height = 1080+16+28+22 = 1146
    const canvasW = 1920, canvasH = 1080;
    const bezelTop = 16, bezelBottom = 28;
    const bezelW = 16 + 16; // left + right bezel  
    const standH = 22; // neck + base
    const tvWidth = canvasW + bezelW;
    const tvHeight = canvasH + bezelTop + bezelBottom + standH;
    
    // Calculate scale with generous padding to ensure full TV + stand is visible
    const paddingX = 120;
    const paddingY = 160; // Extra vertical padding for stand visibility
    const availW = rect.width - paddingX;
    const availH = rect.height - paddingY;
    
    // Use the smaller scale to ensure full TV fits
    const scaleX = availW / tvWidth;
    const scaleY = availH / tvHeight;
    canvasZoom = Math.min(scaleX, scaleY, 0.95); // Cap at 95% max
    
    // The TV frame center is offset from canvas center due to stand
    // Move UP (negative Y) to center the full TV frame including stand
    // Empirically determined: -92px unscaled centers the TV properly
    const verticalOffset = -92;
    canvasPan = { x: 0, y: verticalOffset * canvasZoom };
  }
  
  function resetPan() {
    canvasPan = { x: 0, y: 0 };
  }
  
  // Sidebar resize functions
  function startSidebarResize(e) {
    isResizingSidebar = true;
    sidebarResizeStartX = e.clientX;
    sidebarResizeStartWidth = rightSidebarWidth;
    document.addEventListener('mousemove', handleSidebarResize);
    document.addEventListener('mouseup', stopSidebarResize);
    document.body.style.cursor = 'ew-resize';
    document.body.style.userSelect = 'none';
  }
  
  function handleSidebarResize(e) {
    if (!isResizingSidebar) return;
    const delta = sidebarResizeStartX - e.clientX;
    const newWidth = Math.max(SIDEBAR_MIN_WIDTH, Math.min(SIDEBAR_MAX_WIDTH, sidebarResizeStartWidth + delta));
    rightSidebarWidth = newWidth;
  }
  
  function stopSidebarResize() {
    isResizingSidebar = false;
    document.removeEventListener('mousemove', handleSidebarResize);
    document.removeEventListener('mouseup', stopSidebarResize);
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
  }
  
  function toggleRightSidebar() {
    rightSidebarCollapsed = !rightSidebarCollapsed;
  }

  function handleResize() {
    zoomFit();
  }
  
  // Menu bar functions
  function toggleMenu(menuKey) {
    openMenu = openMenu === menuKey ? null : menuKey;
  }
  
  function closeMenu() {
    openMenu = null;
  }
  
  function handleMenuAction(action) {
    closeMenu();
    
    switch (action) {
      // File menu
      case 'newCast':
        if (hasUnsavedChanges) {
          pendingNavigation = '/ext/slidecast/studio?id=new';
          showUnsavedChangesModal = true;
        } else {
          goto('/ext/slidecast/studio?id=new');
        }
        break;
      case 'save':
        saveCast();
        break;
      case 'saveAsTemplate':
        showSaveAsTemplateModal = true;
        break;
      case 'exportCast':
        exportCast();
        break;
      case 'close':
        if (hasUnsavedChanges) {
          pendingNavigation = '/ext/slidecast';
          showUnsavedChangesModal = true;
        } else {
          goto('/ext/slidecast');
        }
        break;
        
      // Edit menu
      case 'undo':
        undo();
        break;
      case 'redo':
        redo();
        break;
      case 'cut':
        if (selectedElement) {
          clipboardElement = JSON.parse(JSON.stringify(selectedElement));
          elementClipboardOperation = 'cut';
          cutElementSourceGroupId = currentGroupId;
          cutElementSourceSlideIndex = currentSlideIndex;
          cutElementSourceId = selectedElement.id;
        }
        break;
      case 'copy':
        if (selectedElement) {
          clipboardElement = JSON.parse(JSON.stringify(selectedElement));
          elementClipboardOperation = 'copy';
          cutElementSourceGroupId = null;
          cutElementSourceSlideIndex = null;
          cutElementSourceId = null;
        }
        break;
      case 'paste':
        if (clipboardElement) {
          pasteElement();
        }
        break;
      case 'duplicate':
        duplicateSelectedElement();
        break;
      case 'delete':
        deleteSelectedElement();
        break;
      case 'selectAll':
        // For now, just select the last element (multi-select could be added later)
        const slide = getCurrentSlide();
        if (slide?.elements?.length > 0) {
          setSelectedElementId(slide.elements[slide.elements.length - 1].id);
        }
        break;
        
      // View menu
      case 'zoomIn':
        zoomIn();
        break;
      case 'zoomOut':
        zoomOut();
        break;
      case 'zoomFit':
        zoomFit();
        break;
      case 'toggleSlidesPanel':
        showSlidesPanel = !showSlidesPanel;
        if (!showSlidesPanel) slidesPanelCollapsed = true;
        else slidesPanelCollapsed = false;
        break;
      case 'toggleLayersPanel':
        showLayersPanel = !showLayersPanel;
        break;
      case 'togglePropertiesPanel':
        showPropertiesPanel = !showPropertiesPanel;
        break;
      case 'toggleHistoryPanel':
        showHistoryPanel = !showHistoryPanel;
        break;
        
      // Insert menu
      case 'insertText':
        addElement('text');
        break;
      case 'insertImage':
        showMediaModal = true;
        break;
      case 'insertWidget':
        showWidgetModal = true;
        break;
      case 'insertRectangle':
        addElement('shape', { shapeType: 'rectangle' });
        break;
      case 'insertCircle':
        addElement('shape', { shapeType: 'circle' });
        break;
      case 'insertQrCode':
        addElement('qr');
        break;
      case 'insertNav':
        addElement('nav');
        break;
      case 'insertPing':
        addElement('ping');
        break;
        
      // Arrange menu
      case 'bringToFront':
        bringToFront();
        break;
      case 'bringForward':
        bringForward();
        break;
      case 'sendBackward':
        sendBackward();
        break;
      case 'sendToBack':
        sendToBack();
        break;
      case 'alignLeft':
        alignElement('left');
        break;
      case 'alignCenter':
        alignElement('center');
        break;
      case 'alignRight':
        alignElement('right');
        break;
      case 'alignTop':
        alignElement('top');
        break;
      case 'alignMiddle':
        alignElement('middle');
        break;
      case 'alignBottom':
        alignElement('bottom');
        break;
        
      // Cast menu
      case 'canvasSize':
        showCanvasSizeModal = true;
        break;
      case 'background':
        // Select background element for editing
        const bgSlide = getCurrentSlide();
        const bgElement = bgSlide?.elements?.find(el => el.type === 'background');
        if (bgElement) {
          setSelectedElementId(bgElement.id);
        }
        break;
      case 'variables':
        showVariablesModal = true;
        break;
      case 'groups':
        showGroupSettingsModal = true;
        break;
      case 'slideTiming':
        showSlideSettingsModal = true;
        editingSlideIndex = currentSlideIndex;
        break;
        
      // Help menu
      case 'keyboardShortcuts':
        showKeyboardShortcutsModal = true;
        break;
      case 'documentation':
        window.open('https://docs.waiveo.com/slidecast', '_blank');
        break;
    }
  }
  
  // Layer ordering functions
  function bringToFront() {
    if (!selectedElement) return;
    const slide = getCurrentSlide();
    const index = slide.elements.findIndex(el => el.id === selectedElementId);
    if (index === -1 || index === slide.elements.length - 1) return;
    
    const element = slide.elements.splice(index, 1)[0];
    slide.elements.push(element);
    cast = { ...cast };
    const name = selectedElement.name || selectedElement.type;
    pushHistory(`Bring "${name}" to front`);
  }
  
  function bringForward() {
    if (!selectedElement) return;
    const slide = getCurrentSlide();
    const index = slide.elements.findIndex(el => el.id === selectedElementId);
    if (index === -1 || index === slide.elements.length - 1) return;
    
    const element = slide.elements[index];
    slide.elements[index] = slide.elements[index + 1];
    slide.elements[index + 1] = element;
    cast = { ...cast };
    const name = selectedElement.name || selectedElement.type;
    pushHistory(`Bring "${name}" forward`);
  }
  
  function sendBackward() {
    if (!selectedElement) return;
    const slide = getCurrentSlide();
    const index = slide.elements.findIndex(el => el.id === selectedElementId);
    // Don't allow moving below the background (index 0)
    if (index <= 1) return;
    
    const element = slide.elements[index];
    slide.elements[index] = slide.elements[index - 1];
    slide.elements[index - 1] = element;
    cast = { ...cast };
    const name = selectedElement.name || selectedElement.type;
    pushHistory(`Send "${name}" backward`);
  }
  
  function sendToBack() {
    if (!selectedElement) return;
    const slide = getCurrentSlide();
    const index = slide.elements.findIndex(el => el.id === selectedElementId);
    // Don't allow moving below the background (index 0)
    if (index <= 1) return;
    
    const element = slide.elements.splice(index, 1)[0];
    slide.elements.splice(1, 0, element); // Insert after background
    cast = { ...cast };
    const name = selectedElement.name || selectedElement.type;
    pushHistory(`Send "${name}" to back`);
  }
  
  // Alignment functions
  function alignElement(alignment) {
    if (!selectedElement) return;
    const name = selectedElement.name || selectedElement.type;
    
    const canvasWidth = 1920;
    const canvasHeight = 1080;
    
    switch (alignment) {
      case 'left':
        selectedElement.position.x = 0;
        break;
      case 'center':
        selectedElement.position.x = (canvasWidth - selectedElement.size.width) / 2;
        break;
      case 'right':
        selectedElement.position.x = canvasWidth - selectedElement.size.width;
        break;
      case 'top':
        selectedElement.position.y = 0;
        break;
      case 'middle':
        selectedElement.position.y = (canvasHeight - selectedElement.size.height) / 2;
        break;
      case 'bottom':
        selectedElement.position.y = canvasHeight - selectedElement.size.height;
        break;
    }
    
    cast = { ...cast };
    pushHistory(`Align "${name}" ${alignment}`);
    // Auto-run widget after alignment
    scheduleWidgetAutoRun(selectedElement);
  }
  
  // Export cast as JSON
  function exportCast() {
    const dataStr = JSON.stringify(cast, null, 2);
    const dataBlob = new Blob([dataStr], { type: 'application/json' });
    const url = URL.createObjectURL(dataBlob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${cast.name || 'cast'}.json`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }
  
  // Close menu on click outside
  function handleClickOutside(e) {
    if (openMenu && !e.target.closest('.menu-bar')) {
      closeMenu();
    }
  }
  
  // Canvas wheel handler for zooming
  function handleCanvasWheel(e) {
    // Prevent page scroll when over canvas
    e.preventDefault();
    
    // Zoom with scroll wheel
    const delta = e.deltaY > 0 ? -0.05 : 0.05;
    const newZoom = Math.max(0.1, Math.min(2, canvasZoom + delta));
    canvasZoom = newZoom;
  }
  
  // Canvas panning - middle mouse button OR left click with hand tool
  function handleCanvasMouseDown(e) {
    // Middle mouse button (button 1) always pans
    // Left click (button 0) pans only when hand tool is active
    if (e.button === 1 || (e.button === 0 && activeTool === 'hand')) {
      e.preventDefault();
      e.stopPropagation();
      isPanning = true;
      panStart = {
        x: e.clientX,
        y: e.clientY,
        panX: canvasPan.x,
        panY: canvasPan.y
      };
      document.body.style.cursor = 'grabbing';
    }
  }
  
  function handleCanvasPanMove(e) {
    if (!isPanning) return;
    
    const dx = e.clientX - panStart.x;
    const dy = e.clientY - panStart.y;
    
    canvasPan = {
      x: panStart.panX + dx,
      y: panStart.panY + dy
    };
  }
  
  function handleCanvasPanEnd(e) {
    if (isPanning) {
      isPanning = false;
      document.body.style.cursor = '';
    }
  }
  
  // Scroll wheel on number inputs
  function handleNumberInputWheel(e, getValue, setValue, min = -Infinity, max = Infinity, step = 1) {
    e.preventDefault();
    const delta = e.deltaY > 0 ? -step : step;
    const newValue = Math.max(min, Math.min(max, getValue() + delta));
    setValue(newValue);
    cast = { ...cast };
  }

  // Element clipboard (cut/copy/paste)
  let clipboardElement = null;
  let elementClipboardOperation = null; // 'cut' or 'copy'
  let cutElementSourceGroupId = null; // Track which group the cut element came from
  let cutElementSourceSlideIndex = null; // Track which slide the cut element came from
  let cutElementSourceId = null; // Track the original element ID for deletion after paste

  async function handlePaste(e) {
    const items = e.clipboardData?.items;
    if (!items) return;

    for (const item of items) {
      if (item.type.startsWith('image/')) {
        e.preventDefault();
        const blob = item.getAsFile();
        await uploadAndAddImage(blob);
        break;
      }
    }
  }

  // Keyboard shortcuts
  function handleKeyboard(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
    
    // Close menu on Escape
    if (e.key === 'Escape') {
      if (openMenu) {
        closeMenu();
        return;
      }
      selectedElementId = null;
    }
    
    if ((e.key === 'Delete' || e.key === 'Backspace') && selectedElement) {
      e.preventDefault();
      deleteSelectedElement();
    }
    
    // Cut: Ctrl+X
    if ((e.ctrlKey || e.metaKey) && e.key === 'x' && selectedElement) {
      e.preventDefault();
      clipboardElement = JSON.parse(JSON.stringify(selectedElement));
      elementClipboardOperation = 'cut';
      cutElementSourceGroupId = currentGroupId;
      cutElementSourceSlideIndex = currentSlideIndex;
      cutElementSourceId = selectedElement.id;
    }
    
    // Copy: Ctrl+C
    if ((e.ctrlKey || e.metaKey) && e.key === 'c' && selectedElement) {
      e.preventDefault();
      clipboardElement = JSON.parse(JSON.stringify(selectedElement));
      elementClipboardOperation = 'copy';
      cutElementSourceGroupId = null;
      cutElementSourceSlideIndex = null;
      cutElementSourceId = null;
    }
    
    // Paste: Ctrl+V
    if ((e.ctrlKey || e.metaKey) && e.key === 'v' && clipboardElement && !e.clipboardData?.items) {
        e.preventDefault();
      pasteElement();
    }
    
    // Duplicate: Ctrl+D
    if ((e.ctrlKey || e.metaKey) && e.key === 'd' && selectedElement) {
      e.preventDefault();
      duplicateSelectedElement();
    }
    
    // Save: Ctrl+S
    if ((e.ctrlKey || e.metaKey) && e.key === 's') {
      e.preventDefault();
      saveCast();
    }
    
    // Undo: Ctrl+Z
    if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
      e.preventDefault();
      undo();
    }
    
    // Redo: Ctrl+Y or Ctrl+Shift+Z
    if ((e.ctrlKey || e.metaKey) && (e.key === 'y' || (e.key === 'z' && e.shiftKey) || (e.key === 'Z' && e.shiftKey))) {
      e.preventDefault();
      redo();
    }
    
    // Zoom: Ctrl+Plus/Minus/0
    if ((e.ctrlKey || e.metaKey) && (e.key === '=' || e.key === '+')) {
      e.preventDefault();
      zoomIn();
    }
    if ((e.ctrlKey || e.metaKey) && e.key === '-') {
      e.preventDefault();
      zoomOut();
    }
    if ((e.ctrlKey || e.metaKey) && e.key === '0') {
      e.preventDefault();
      zoomFit();
    }
    
    // Tool shortcuts (no modifier needed)
    if (e.key === 'v' || e.key === 'V') {
      if (!e.ctrlKey && !e.metaKey) {
        activeTool = 'pointer';
      }
    }
    if (e.key === 'h' || e.key === 'H') {
      activeTool = 'hand';
    }

    // Layer ordering: Ctrl+]/[ and Ctrl+Shift+]/[
    if ((e.ctrlKey || e.metaKey) && e.key === ']' && !e.shiftKey && selectedElement) {
      e.preventDefault();
      bringForward();
    }
    if ((e.ctrlKey || e.metaKey) && e.key === ']' && e.shiftKey && selectedElement) {
      e.preventDefault();
      bringToFront();
    }
    if ((e.ctrlKey || e.metaKey) && e.key === '[' && !e.shiftKey && selectedElement) {
      e.preventDefault();
      sendBackward();
    }
    if ((e.ctrlKey || e.metaKey) && e.key === '[' && e.shiftKey && selectedElement) {
      e.preventDefault();
      sendToBack();
    }
    
    // Keyboard shortcuts help: Ctrl+?
    if ((e.ctrlKey || e.metaKey) && e.key === '?') {
      e.preventDefault();
      showKeyboardShortcutsModal = true;
    }
    
    if (selectedElement && ['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {
      e.preventDefault();
      const step = e.shiftKey ? 10 : 1;
      const slide = getCurrentSlide();
      const el = slide.elements.find(el => el.id === selectedElementId);
      if (el) {
        if (e.key === 'ArrowUp') el.position.y -= step;
        if (e.key === 'ArrowDown') el.position.y += step;
        if (e.key === 'ArrowLeft') el.position.x -= step;
        if (e.key === 'ArrowRight') el.position.x += step;
        cast = { ...cast }; // Trigger reactivity
        
        // Sync to linked navs
        if (el.type === 'nav' && el.scope !== 'slide' && !el._isInheritedCopy) {
          syncNavChanges(el);
        }
      }
    }
  }

  function pasteElement() {
    const slide = getCurrentSlide();
    if (!slide || !clipboardElement) return;
    
    const newElement = JSON.parse(JSON.stringify(clipboardElement));
    newElement.id = generateId();
    newElement.position.x += 20;
    newElement.position.y += 20;
    newElement.zIndex = slide.elements.length;
    slide.elements.push(newElement);
    selectedElementId = newElement.id;
    
    // If this was a cut operation, delete the original element silently (no modal)
    if (elementClipboardOperation === 'cut' && cutElementSourceGroupId && cutElementSourceSlideIndex !== null && cutElementSourceId) {
      deleteElementSilently(cutElementSourceGroupId, cutElementSourceSlideIndex, cutElementSourceId);
      // Clear the cut state - element can only be pasted once from a cut
      elementClipboardOperation = 'copy'; // Convert to copy so subsequent pastes don't re-delete
      cutElementSourceGroupId = null;
      cutElementSourceSlideIndex = null;
      cutElementSourceId = null;
    }
    
    cast = { ...cast };
    const name = newElement.name || newElement.type;
    pushHistory(`Paste "${name}"`);
  }
  
  // Delete an element without showing confirmation modal (used for cut/paste)
  function deleteElementSilently(groupId, slideIndex, elementId) {
    const group = cast?.definition?.groups?.find(g => g.id === groupId);
    if (!group?.slides?.[slideIndex]) return;
    
    const slide = group.slides[slideIndex];
    const index = slide.elements.findIndex(el => el.id === elementId);
    if (index !== -1) {
      slide.elements.splice(index, 1);
      // If the deleted element was selected, clear selection
      if (selectedElementId === elementId) {
        selectedElementId = null;
      }
    }
  }

  // Element operations
  function addElement(type, config = {}) {
    const slide = getCurrentSlide();
    if (!slide) return;

    // Count elements of this type for naming
    const typeCount = slide.elements.filter(el => el.type === type).length + 1;
    const typeName = type.charAt(0).toUpperCase() + type.slice(1);

    let element = {
      id: generateId(),
      type,
      name: `${typeName} ${typeCount}`,
      position: { x: 100, y: 100 },
      size: { width: 200, height: 100 },
      zIndex: slide.elements.length,
      style: { opacity: 1 }
    };

    switch (type) {
      case 'text':
        element.content = 'Double-click to edit';
        element.size = { width: 400, height: 80 };
        element.style = {
          fontFamily: 'Inter',
          fontSize: 48,
          fontWeight: 'bold',
          fontStyle: 'normal',
          textDecoration: 'none',
          color: '#ffffff',
          textAlign: 'left',
          lineHeight: 1.2,
          letterSpacing: 0,
          strokeColor: '#000000',
          strokeWidth: 0,
          opacity: 1
        };
        break;
      
      case 'shape':
        element.shape = config.shape || 'rectangle';
        element.size = { width: 200, height: 200 };
        element.style = {
          fill: '#3b82f6',
          borderRadius: 8,
          opacity: 1
        };
        break;
      
      case 'image':
        element.asset_id = config.asset_id;
        element.size = { width: 400, height: 300 };
        element.style = { opacity: 1, objectFit: 'cover' };
        break;
      
      case 'video':
        element.asset_id = config.asset_id;
        element.position = { x: 0, y: 0 };
        element.size = { width: 1920, height: 1080 };
        element.zIndex = 1; // Above background
        element.playback = { loop: true, muted: true, autoplay: true };
        element.style = { opacity: 1, objectFit: 'cover' };
        break;
      
      case 'nav':
        element.layout = 'horizontal';
        element.position = { x: 100, y: 900 };
        element.size = { width: 280, height: 56 };
        element.items = [
          { id: generateId(), label: 'Home', iconClass: 'fa-solid fa-house', action: { type: 'slide', slide_index: 0, group_id: currentGroupId } },
          { id: generateId(), label: 'Info', iconClass: 'fa-solid fa-circle-info', action: { type: 'slide', slide_index: 1, group_id: currentGroupId } }
        ];
        // Scope settings - determines inheritance
        element.scope = 'slide';  // 'cast' | 'group' | 'slide'
        element.sourceGroupId = currentGroupId;  // For group-scoped navs
        element.syncPosition = true;  // Position synced across slides?
        element.syncStyle = true;  // Style synced across slides?
        // Default: Unified Bar preset
        element.style = {
          preset: 'unified-bar',
          // Container
          containerBackground: '#000000',
          containerOpacity: 0.6,
          containerRadius: 16,
          containerPadding: 8,
          containerBlur: 0,
          // Items
          itemBackgroundColor: '#ffffff',
          itemBackgroundOpacity: 0,
          itemColor: '#ffffff',
          itemPadding: 12,
          itemGap: 4,
          itemBorderRadius: 8,
          fontSize: 15,
          iconSize: 18,
          iconPosition: 'left',
          // Active state
          activeBackgroundColor: '#6366f1',
          activeBackgroundOpacity: 0.9,
          activeTextColor: '#ffffff',
          activeIndicator: 'background',
          // Hover
          hoverBackgroundColor: '#ffffff',
          hoverBackgroundOpacity: 0.15,
          hoverScale: 1.02,
          // Overall
          opacity: 1
        };
        break;
      
      case 'ping':
        element.label = 'Press for Help';
        element.icon = '●';
        element.ping_name = 'help_requested';
        element.position = { x: 100, y: 950 };
        element.size = { width: 250, height: 60 };
        element.style = {
          background: '#ef4444',
          color: '#ffffff',
          fontSize: 20,
          borderRadius: 8,
          opacity: 1
        };
        break;
      
      case 'qrcode':
        element.qrType = 'url';
        element.data = 'https://example.com';
        element.qrUrl = 'https://example.com';
        element.size = { width: 200, height: 200 };
        element.style = {
          foreground: '#000000',
          background: '#ffffff',
          opacity: 1
        };
        break;
      
      case 'widget':
        const widget = availableWidgets.find(w => w.uuid === config.widgetUuid);
        element.widgetUuid = config.widgetUuid;
        element.widgetName = widget?.name || 'Widget';
        // Use the widget's actual name for the layer
        element.name = widget?.name || 'Widget';
        
        // Populate defaults from configSchema
        const defaultConfig = {};
        if (widget?.configSchema) {
          for (const [key, schema] of Object.entries(widget.configSchema)) {
            defaultConfig[key] = schema.default;
          }
        }
        element.widgetConfig = { ...defaultConfig, ...(config.widgetConfig || {}) };
        
        // Populate defaults from styleSchema
        const defaultStyles = {};
        if (widget?.styleSchema) {
          for (const [key, schema] of Object.entries(widget.styleSchema)) {
            defaultStyles[key] = schema.default;
          }
        }
        element.widgetStyles = { ...defaultStyles, ...(config.widgetStyles || {}) };
        
        element.size = widget?.defaultSize || { width: 300, height: 150 };
        element.refreshInterval = widget?.refreshInterval || 60000;
        element.style = { opacity: 1 };
        // Set preview primitives for Studio canvas display
        if (widget?.previewPrimitives) {
          element._widgetRenderMode = 'native';
          element._widgetPrimitives = widget.previewPrimitives;
        }
        break;
    }

    slide.elements.push(element);
    selectedElementId = element.id;
    // Trigger Svelte reactivity by creating a new reference
    cast = { ...cast };
    pushHistory(`Add ${element.name}`);
  }

  function deleteSelectedElement() {
    if (!selectedElementId) return;
    confirmDeleteLayer(selectedElementId);
  }
  
  // Show confirmation modal before deleting layer
  function confirmDeleteLayer(elementId) {
    pendingDeleteLayerId = elementId;
    showDeleteLayerModal = true;
  }
  
  // Actually delete the layer after confirmation
  function executeDeleteLayer() {
    if (!pendingDeleteLayerId) return;
    const slide = getCurrentSlide();
    const index = slide.elements.findIndex(el => el.id === pendingDeleteLayerId);
    if (index !== -1) {
      const element = slide.elements[index];
      const name = element.name || element.type;
      slide.elements.splice(index, 1);
      if (selectedElementId === pendingDeleteLayerId) selectedElementId = null;
      cast = { ...cast };
      pushHistory(`Delete "${name}"`);
    }
    showDeleteLayerModal = false;
    pendingDeleteLayerId = null;
  }
  
  // Legacy function for direct delete (used by keyboard shortcut with immediate action)
  function deleteElement(elementId) {
    confirmDeleteLayer(elementId);
  }

  function duplicateSelectedElement() {
    if (!selectedElement) return;
    duplicateElement(selectedElement);
  }

  function duplicateElement(element) {
    if (!element || element.type === 'background') return; // Can't duplicate background
    const slide = getCurrentSlide();
    if (!slide) return;
    
    // Count elements of this type for naming
    const typeCount = slide.elements.filter(el => el.type === element.type).length + 1;
    const typeName = element.type.charAt(0).toUpperCase() + element.type.slice(1);
    
    const newElement = JSON.parse(JSON.stringify(element));
    newElement.id = generateId();
    newElement.name = `${typeName} ${typeCount}`;
    newElement.position.x += 20;
    newElement.position.y += 20;
    newElement.zIndex = slide.elements.length;
    slide.elements.push(newElement);
    selectedElementId = newElement.id;
    cast = { ...cast };
    const origName = element.name || element.type;
    pushHistory(`Duplicate "${origName}"`);
  }

  // Media handling
  async function uploadAndAddImage(blob) {
    try {
      const reader = new FileReader();
      reader.onload = async () => {
        const base64 = reader.result.split(',')[1];
        const response = await fetch('/api/extensions/slidecast/media/base64', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: `Pasted Image ${new Date().toLocaleTimeString()}`,
            data: base64,
            mime_type: blob.type
          })
        });
        
        const data = await response.json();
        if (data.success) {
          addElement('image', { asset_id: data.media.uuid });
          await loadMedia();
        }
      };
      reader.readAsDataURL(blob);
    } catch (err) {
      console.error('Failed to upload pasted image:', err);
    }
  }

  async function handleMediaDrop(e) {
    isDraggingMedia = false;
    const files = e.dataTransfer?.files;
    if (files?.length > 0) {
      await uploadMediaFile(files[0]);
    }
  }

  async function handleMediaFileSelect(e) {
    const files = e.target.files;
    if (files?.length > 0) {
      await uploadMediaFile(files[0]);
    }
    if (mediaFileInput) mediaFileInput.value = '';
  }

  // Handle multiple files from MediaModal upload event
  async function handleMediaUpload(files) {
    if (!files?.length) return;
    for (const file of files) {
      await uploadMediaFile(file);
    }
  }
  
  // Refresh widget data (trigger re-render by running the widget)
  function refreshWidget(widget) {
    if (!widget) return;
    // Actually run the widget to fetch fresh data
    runWidget(widget);
  }

  async function uploadMediaFile(file) {
    if (!file) return;
    uploadingMedia = true;
    
    try {
      console.log('Uploading file:', file.name, file.size, file.type);
      
      // Use proper multipart form upload
      const formData = new FormData();
      formData.append('file', file);
      
      const response = await fetch('/api/extensions/slidecast/media/upload', {
        method: 'POST',
        body: formData
        // Don't set Content-Type - browser sets it automatically with boundary
      });
      
      console.log('Response status:', response.status);
      const data = await response.json();
      console.log('Response data:', data);
      
      if (data.success) {
        await loadMedia();
        selectMedia(data.media);
      } else {
        console.error('Upload failed:', data.error);
        alert('Upload failed: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      console.error('Failed to upload media:', err);
      alert('Upload failed: ' + err.message);
    } finally {
      uploadingMedia = false;
    }
  }

  function selectMedia(media) {
    if (media.type === 'video') {
      addElement('video', { asset_id: media.uuid });
    } else {
      addElement('image', { asset_id: media.uuid });
    }
    showMediaModal = false;
  }
  
  async function importFromUrl() {
    if (!importUrl) return;
    importingUrl = true;
    try {
      const response = await fetch('/api/extensions/slidecast/media/import-url', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url: importUrl })
      });
      const result = await response.json();
      if (result.success) {
        mediaLibrary = [...mediaLibrary, result.media];
        selectMedia(result.media);
        importUrl = '';
      } else {
        alert('Failed to import: ' + result.error);
      }
    } catch (error) {
      alert('Import failed: ' + error.message);
    } finally {
      importingUrl = false;
    }
  }

  // Group management
  function addGroup(name) {
    if (!cast?.definition?.groups) return;
    
    const groupName = name || `Group ${cast.definition.groups.length}`;
    const newGroup = {
      id: 'group-' + generateId(),
      name: groupName,
      isDefault: false,
      loop: true,
      defaultDuration: 10000,
      slides: [{
        id: generateId(),
        name: 'Slide',
        duration: 10000,
        backgroundColor: cast.definition.settings.backgroundColor || '#1a1a2e',
        elements: [{
          id: generateId(),
          type: 'background',
          name: 'Background',
          locked: true,
          position: { x: 0, y: 0 },
          size: { width: 1920, height: 1080 },
          zIndex: 0,
          style: { backgroundColor: cast.definition.settings.backgroundColor || '#1a1a2e' }
        }]
      }]
    };
    
    cast.definition.groups.push(newGroup);
    currentGroupId = newGroup.id;
    currentSlideIndex = 0;
    selectedElementId = null;
    cast = { ...cast };
    pushHistory(`Add group "${groupName}"`);
  }
  
  // Show confirmation modal before deleting group
  function confirmDeleteGroup(groupId) {
    if (!cast?.definition?.groups || groupId === 'home') return; // Can't delete Home
    if (cast.definition.groups.length <= 1) return;
    pendingDeleteGroupId = groupId;
    showDeleteGroupModal = true;
  }
  
  // Actually delete the group after confirmation
  function executeDeleteGroup() {
    if (!pendingDeleteGroupId) return;
    if (!cast?.definition?.groups || pendingDeleteGroupId === 'home') {
      showDeleteGroupModal = false;
      pendingDeleteGroupId = null;
      return;
    }
    
    const index = cast.definition.groups.findIndex(g => g.id === pendingDeleteGroupId);
    if (index >= 0) {
      const groupName = cast.definition.groups[index].name;
      cast.definition.groups.splice(index, 1);
      // Switch to home if we deleted the current group
      if (currentGroupId === pendingDeleteGroupId) {
        currentGroupId = 'home';
        currentSlideIndex = 0;
      }
      selectedElementId = null;
      cast = { ...cast };
      pushHistory(`Delete group "${groupName}"`);
    }
    showDeleteGroupModal = false;
    pendingDeleteGroupId = null;
  }
  
  // Legacy function name for compatibility
  function deleteGroup(groupId) {
    confirmDeleteGroup(groupId);
  }
  
  function selectGroup(groupId) {
    if (currentGroupId === groupId) return;
    currentGroupId = groupId;
    currentSlideIndex = 0;
    selectedElementId = null;
    // Auto-run all widgets on the first slide of the new group
    runAllWidgetsOnSlide();
  }

  // ============================================
  // NAV SCOPE & INHERITANCE SYSTEM
  // ============================================
  
  // Get all cast-level navs (scope === 'cast')
  function getCastLevelNavs() {
    if (!cast?.definition?.groups) return [];
    const navs = [];
    for (const group of cast.definition.groups) {
      for (const slide of group.slides || []) {
        for (const element of slide.elements || []) {
          if (element.type === 'nav' && element.scope === 'cast') {
            // Only include if not already in the list (by original ID)
            if (!navs.find(n => n.id === element.id)) {
              navs.push(element);
            }
          }
        }
      }
    }
    return navs;
  }
  
  // Get all group-level navs for a specific group
  function getGroupLevelNavs(groupId) {
    const group = cast?.definition?.groups?.find(g => g.id === groupId);
    if (!group) return [];
    const navs = [];
    for (const slide of group.slides || []) {
      for (const element of slide.elements || []) {
        if (element.type === 'nav' && element.scope === 'group' && element.sourceGroupId === groupId) {
          if (!navs.find(n => n.id === element.id)) {
            navs.push(element);
          }
        }
      }
    }
    return navs;
  }
  
  // Get inherited navs for current slide (cast-level + group-level)
  function getInheritedNavs() {
    const castNavs = getCastLevelNavs();
    const groupNavs = getGroupLevelNavs(currentGroupId);
    return [...castNavs, ...groupNavs];
  }
  
  // Check if a nav element is inherited (not originally from this slide)
  function isNavInherited(element, slide) {
    if (element.type !== 'nav') return false;
    if (element.scope === 'slide') return false;
    // Check if this is the original source
    if (element._isInheritedCopy) return true;
    return false;
  }
  
  // Create an inherited copy of a nav for a new slide
  function createInheritedNavCopy(sourceNav, newSlideId) {
    return {
      ...JSON.parse(JSON.stringify(sourceNav)),
      _isInheritedCopy: true,
      _sourceNavId: sourceNav.id,
      // Keep same ID so it's treated as same nav across slides
      // But mark it so we know it's inherited
    };
  }
  
  // When nav scope changes, propagate to all relevant slides
  function propagateNavToScope(nav, newScope, oldScope, oldGroupId = null) {
    if (!cast?.definition?.groups) return;
    
    const sourceSlide = currentSlide;
    const sourceGroup = getCurrentGroup();
    const targetGroupId = nav.sourceGroupId || currentGroupId;
    const targetGroup = cast.definition.groups.find(g => g.id === targetGroupId);
    
    if (newScope === 'cast') {
      // Add nav to all slides in all groups
      for (const group of cast.definition.groups) {
        for (const slide of group.slides || []) {
          if (slide.id === sourceSlide.id) continue; // Skip source
          // Check if nav already exists
          const existing = slide.elements?.find(e => e.id === nav.id || e._sourceNavId === nav.id);
          if (!existing) {
            const copy = createInheritedNavCopy(nav, slide.id);
            slide.elements = slide.elements || [];
            slide.elements.push(copy);
          }
        }
      }
    } else if (newScope === 'group') {
      // If group changed, remove from old group first
      if (oldGroupId && oldGroupId !== targetGroupId) {
        const oldGroup = cast.definition.groups.find(g => g.id === oldGroupId);
        if (oldGroup) {
          for (const slide of oldGroup.slides || []) {
            slide.elements = (slide.elements || []).filter(e => 
              e.id !== nav.id && e._sourceNavId !== nav.id
            );
          }
        }
      }
      
      // Add nav to all slides in target group only
      if (targetGroup) {
        for (const slide of targetGroup.slides || []) {
          if (slide.id === sourceSlide.id) continue;
          const existing = slide.elements?.find(e => e.id === nav.id || e._sourceNavId === nav.id);
          if (!existing) {
            const copy = createInheritedNavCopy(nav, slide.id);
            slide.elements = slide.elements || [];
            slide.elements.push(copy);
          }
        }
      }
      
      // Remove from other groups if was cast-level
      if (oldScope === 'cast') {
        for (const group of cast.definition.groups) {
          if (group.id === targetGroupId) continue;
          for (const slide of group.slides || []) {
            slide.elements = (slide.elements || []).filter(e => 
              e.id !== nav.id && e._sourceNavId !== nav.id
            );
          }
        }
      }
    } else if (newScope === 'slide') {
      // Remove from all other slides
      for (const group of cast.definition.groups) {
        for (const slide of group.slides || []) {
          if (slide.id === sourceSlide.id) continue;
          slide.elements = (slide.elements || []).filter(e => 
            e.id !== nav.id && e._sourceNavId !== nav.id
          );
        }
      }
    }
    
    cast = { ...cast };
  }
  
  // Sync nav position/style changes to all inherited copies
  function syncNavChanges(nav) {
    if (!cast?.definition?.groups || nav.scope === 'slide') return;
    
    for (const group of cast.definition.groups) {
      if (nav.scope === 'group' && group.id !== nav.sourceGroupId) continue;
      
      for (const slide of group.slides || []) {
        for (const element of slide.elements || []) {
          // Skip the source element itself
          if (element.id === nav.id && !element._isInheritedCopy) continue;
          
          if (element.id === nav.id || element._sourceNavId === nav.id) {
            // Sync ALL properties - position, size, style, layout, items, everything
            element.position = { ...nav.position };
            element.size = { ...nav.size };
            element.style = JSON.parse(JSON.stringify(nav.style));
            element.layout = nav.layout;
            element.items = JSON.parse(JSON.stringify(nav.items));
            element.name = nav.name;
            // Sync scope settings
            element.scope = nav.scope;
            element.sourceGroupId = nav.sourceGroupId;
            element.syncPosition = nav.syncPosition;
            element.syncStyle = nav.syncStyle;
          }
        }
      }
    }
    
    // Trigger reactivity
    cast = { ...cast };
  }
  
  // Make a local copy of an inherited nav (detach from source)
  function makeNavLocal(element) {
    element.scope = 'slide';
    element._isInheritedCopy = false;
    element._sourceNavId = null;
    element.id = generateId(); // New unique ID
    cast = { ...cast };
  }
  
  // Navigate to source slide of inherited nav
  function goToNavSource(element) {
    if (!element._sourceNavId) return;
    
    // Find the source slide
    for (const group of cast?.definition?.groups || []) {
      for (let slideIndex = 0; slideIndex < (group.slides || []).length; slideIndex++) {
        const slide = group.slides[slideIndex];
        const sourceNav = slide.elements?.find(e => e.id === element._sourceNavId && !e._isInheritedCopy);
        if (sourceNav) {
          currentGroupId = group.id;
          currentSlideIndex = slideIndex;
          selectedElementId = sourceNav.id;
          cast = { ...cast };
          return;
        }
      }
    }
  }

  // Slide management
  function addSlide() {
    const group = getCurrentGroup();
    if (!group) return;

    // Collect inherited navs that should appear on new slide
    const castNavs = getCastLevelNavs();
    const groupNavs = getGroupLevelNavs(currentGroupId);
    const inheritedElements = [];
    
    for (const nav of [...castNavs, ...groupNavs]) {
      inheritedElements.push(createInheritedNavCopy(nav, generateId()));
    }

    const slideName = 'Slide';
    // Use group's default background color, falling back to global settings
    const defaultBgColor = group.defaultBackgroundColor || cast.definition.settings?.backgroundColor || '#1a1a2e';
    const newSlide = {
      id: generateId(),
      name: slideName,
      duration: group.defaultDuration || 10000,
      backgroundColor: defaultBgColor,
      navOverrides: {}, // Store position/style overrides for inherited navs
      elements: [
        {
          id: generateId(),
          type: 'background',
          name: 'Background',
          locked: true,
          position: { x: 0, y: 0 },
          size: { width: 1920, height: 1080 },
          zIndex: 0,
          style: { backgroundColor: defaultBgColor }
        },
        ...inheritedElements
      ]
    };

    group.slides.push(newSlide);
    currentSlideIndex = group.slides.length - 1;
    selectedElementId = null;
    cast = { ...cast };
    pushHistory(`Add "${slideName}"`);
  }

  // Show confirmation modal before deleting slide
  function confirmDeleteSlide(index) {
    const group = getCurrentGroup();
    if (!group || group.slides.length <= 1) return;
    pendingDeleteSlideIndex = index;
    showDeleteSlideModal = true;
  }
  
  // Actually delete the slide after confirmation
  function executeDeleteSlide() {
    if (pendingDeleteSlideIndex === null) return;
    const group = getCurrentGroup();
    if (!group || group.slides.length <= 1) {
      showDeleteSlideModal = false;
      pendingDeleteSlideIndex = null;
      return;
    }
    
    const slideName = group.slides[pendingDeleteSlideIndex].name || `Slide ${pendingDeleteSlideIndex + 1}`;
    group.slides.splice(pendingDeleteSlideIndex, 1);
    if (currentSlideIndex >= group.slides.length) {
      currentSlideIndex = group.slides.length - 1;
    }
    selectedElementId = null;
    cast = { ...cast };
    pushHistory(`Delete "${slideName}"`);
    showDeleteSlideModal = false;
    pendingDeleteSlideIndex = null;
  }
  
  // Legacy function name for compatibility
  function deleteSlide(index) {
    confirmDeleteSlide(index);
  }

  function selectSlide(index) {
    currentSlideIndex = index;
    selectedElementId = null;
    // Auto-run all widgets on the newly selected slide
    runAllWidgetsOnSlide();
  }
  
  // Slide drag reorder handlers
  function handleSlideDragStart(e, index) {
    draggedSlideIndex = index;
    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('text/plain', index.toString());
    e.target.classList.add('dragging');
  }
  
  function handleSlideDragOver(e, index) {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    dragOverSlideIndex = index;
  }
  
  function handleSlideDragLeave(e) {
    // Only clear if leaving the slides list area
    if (!e.relatedTarget?.closest('.slides-list')) {
      dragOverSlideIndex = null;
    }
  }
  
  function handleSlideDrop(e, targetIndex) {
    e.preventDefault();
    if (draggedSlideIndex === null || draggedSlideIndex === targetIndex) {
      draggedSlideIndex = null;
      dragOverSlideIndex = null;
      return;
    }
    
    const group = getCurrentGroup();
    if (!group) return;
    
    // Remove slide from original position
    const [movedSlide] = group.slides.splice(draggedSlideIndex, 1);
    const slideName = movedSlide.name || `Slide ${draggedSlideIndex + 1}`;
    
    // Insert at new position (adjust if moving forward)
    const insertIndex = targetIndex > draggedSlideIndex ? targetIndex : targetIndex;
    group.slides.splice(insertIndex, 0, movedSlide);
    
    // Update current slide index if needed
    if (currentSlideIndex === draggedSlideIndex) {
      currentSlideIndex = insertIndex;
    } else if (currentSlideIndex > draggedSlideIndex && currentSlideIndex <= targetIndex) {
      currentSlideIndex--;
    } else if (currentSlideIndex < draggedSlideIndex && currentSlideIndex >= targetIndex) {
      currentSlideIndex++;
    }
    
    cast = { ...cast };
    pushHistory(`Reorder "${slideName}"`);
    draggedSlideIndex = null;
    dragOverSlideIndex = null;
  }
  
  function handleSlideDragEnd(e) {
    e.target.classList.remove('dragging');
    draggedSlideIndex = null;
    dragOverSlideIndex = null;
  }
  
  // Layer drag reorder handlers
  function handleLayerDragStart(e, element) {
    if (element.locked || element.type === 'background') {
      e.preventDefault();
      return;
    }
    draggedLayerId = element.id;
    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('text/plain', element.id);
    e.target.classList.add('dragging');
  }
  
  function handleLayerDragOver(e, element) {
    e.preventDefault();
    if (element.type === 'background' || element.locked) return;
    e.dataTransfer.dropEffect = 'move';
    dragOverLayerId = element.id;
  }
  
  function handleLayerDragLeave(e) {
    if (!e.relatedTarget?.closest('.layers-list-inline')) {
      dragOverLayerId = null;
    }
  }
  
  function handleLayerDrop(e, targetElement) {
    e.preventDefault();
    if (!draggedLayerId || draggedLayerId === targetElement.id || targetElement.type === 'background') {
      draggedLayerId = null;
      dragOverLayerId = null;
      return;
    }
    
    const slide = getCurrentSlide();
    if (!slide) return;
    
    const elements = slide.elements;
    const draggedIndex = elements.findIndex(el => el.id === draggedLayerId);
    const targetIndex = elements.findIndex(el => el.id === targetElement.id);
    
    if (draggedIndex === -1 || targetIndex === -1) {
      draggedLayerId = null;
      dragOverLayerId = null;
      return;
    }
    
    const draggedEl = elements[draggedIndex];
    const layerName = draggedEl.name || draggedEl.type;
    
    // Remove from original position
    elements.splice(draggedIndex, 1);
    
    // Insert at new position
    elements.splice(targetIndex, 0, draggedEl);
    
    // Update zIndex values to match new order
    elements.forEach((el, i) => el.zIndex = i);
    
    cast = { ...cast };
    pushHistory(`Reorder "${layerName}" layer`);
    draggedLayerId = null;
    dragOverLayerId = null;
  }
  
  function handleLayerDragEnd(e) {
    e.target.classList.remove('dragging');
    draggedLayerId = null;
    dragOverLayerId = null;
  }
  
  // Slide clipboard operations
  function cutSlide(index) {
    const group = getCurrentGroup();
    if (!group || !group.slides[index]) return;
    
    slideClipboard = {
      slide: JSON.parse(JSON.stringify(group.slides[index])),
      sourceGroupId: currentGroupId,
      sourceIndex: index
    };
    clipboardOperation = 'cut';
    // Show paste modal immediately for cut operation
    showPasteSlideModal = true;
  }
  
  function copySlide(index) {
    const group = getCurrentGroup();
    if (!group || !group.slides[index]) return;
    
    slideClipboard = {
      slide: JSON.parse(JSON.stringify(group.slides[index])),
      sourceGroupId: currentGroupId,
      sourceIndex: index
    };
    clipboardOperation = 'copy';
  }
  
  function duplicateSlide(index) {
    const group = getCurrentGroup();
    if (!group || !group.slides[index]) return;
    
    const origName = group.slides[index].name || `Slide ${index + 1}`;
    
    // Create a deep copy with new IDs
    const duplicatedSlide = JSON.parse(JSON.stringify(group.slides[index]));
    duplicatedSlide.id = generateId();
    duplicatedSlide.name = `${duplicatedSlide.name} (copy)`;
    
    // Generate new IDs for all elements
    duplicatedSlide.elements = duplicatedSlide.elements.map(el => ({
      ...el,
      id: generateId()
    }));
    
    // Insert after the original
    group.slides.splice(index + 1, 0, duplicatedSlide);
    
    cast = { ...cast };
    currentSlideIndex = index + 1;
    pushHistory(`Duplicate "${origName}"`);
  }
  
  function showPasteOptions() {
    if (!slideClipboard) return;
    showPasteSlideModal = true;
  }
  
  function pasteSlideToGroup(targetGroupId) {
    if (!slideClipboard) return;
    
    const targetGroup = cast.definition.groups.find(g => g.id === targetGroupId);
    if (!targetGroup) return;
    
    const slideName = slideClipboard.slide.name || 'Slide';
    const operation = clipboardOperation === 'cut' ? 'Move' : 'Paste';
    
    // Create new slide with new IDs
    const newSlide = JSON.parse(JSON.stringify(slideClipboard.slide));
    newSlide.id = generateId();
    newSlide.elements = newSlide.elements.map(el => ({
      ...el,
      id: generateId()
    }));
    
    // If cut operation, remove from source
    if (clipboardOperation === 'cut') {
      const sourceGroup = cast.definition.groups.find(g => g.id === slideClipboard.sourceGroupId);
      if (sourceGroup) {
        const sourceIndex = sourceGroup.slides.findIndex(s => s.id === slideClipboard.slide.id);
        if (sourceIndex >= 0) {
          sourceGroup.slides.splice(sourceIndex, 1);
          // Adjust current slide index if we're in the source group
          if (currentGroupId === slideClipboard.sourceGroupId && currentSlideIndex >= sourceIndex) {
            currentSlideIndex = Math.max(0, currentSlideIndex - 1);
          }
        }
      }
      slideClipboard = null;
      clipboardOperation = null;
    }
    
    // Add to target group
    targetGroup.slides.push(newSlide);
    
    // Switch to target group and select new slide
    currentGroupId = targetGroupId;
    currentSlideIndex = targetGroup.slides.length - 1;
    
    cast = { ...cast };
    pushHistory(`${operation} "${slideName}" to ${targetGroup.name}`);
    showPasteSlideModal = false;
  }

  // Save
  async function saveCast() {
    if (!cast) return;
    saving = true;
    
    try {
      const method = cast.id ? 'PUT' : 'POST';
      const url = cast.id 
        ? `/api/extensions/slidecast/casts/${cast.id}`
        : '/api/extensions/slidecast/casts';
      
      const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: cast.name,
          description: cast.description,
          definition: cast.definition
        })
      });

      const data = await response.json();
      if (data.success) {
        if (!cast.id) {
          const newUrl = `/ext/slidecast/studio?id=${data.cast.uuid}`;
          window.history.replaceState({}, '', newUrl);
          castId = data.cast.uuid;
        }
        cast = data.cast;
        hasUnsavedChanges = false; // Reset after successful save
      }
    } catch (err) {
      console.error('Failed to save:', err);
    } finally {
      saving = false;
    }
  }

  // Save as Template
  async function saveAsTemplate() {
    if (!cast) return;
    savingTemplate = true;
    
    try {
      const response = await fetch('/api/extensions/slidecast/templates', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: templateName || cast.name,
          description: templateDescription || cast.description || '',
          definition: {
            cast: cast.definition
          },
          author: 'User'
        })
      });
      
      const data = await response.json();
      if (data.success) {
        showSaveAsTemplateModal = false;
        templateName = '';
        templateDescription = '';
        // Show success toast or message
        alert('Template saved successfully!');
      } else {
        alert('Failed to save template: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      console.error('Failed to save template:', err);
      alert('Failed to save template');
    } finally {
      savingTemplate = false;
    }
  }

  // Preview - shows current canvas state without saving
  function openBrowserPreview() {
    // Store current cast data in sessionStorage for preview to use
    const previewData = {
      ...cast,
      _previewTimestamp: Date.now() // Mark as preview data
    };
    sessionStorage.setItem('slidecast_preview_data', JSON.stringify(previewData));
    
    // Open preview as a true fullscreen popup (hides browser UI)
    const previewId = cast?.uuid || 'preview';
    const previewUrl = `/ext/slidecast/preview?id=${previewId}&live=true`;
    
    // Get screen dimensions for fullscreen
    const screenWidth = window.screen.width;
    const screenHeight = window.screen.height;
    
    // Popup window features for minimal browser chrome
    const features = [
      `width=${screenWidth}`,
      `height=${screenHeight}`,
      'left=0',
      'top=0',
      'menubar=no',
      'toolbar=no',
      'location=no',
      'status=no',
      'resizable=yes',
      'scrollbars=no',
      'fullscreen=yes'
    ].join(',');
    
    const previewWindow = window.open(previewUrl, 'slidecast_preview', features);
    
    // Try to enter browser fullscreen mode in the new window
    if (previewWindow) {
      previewWindow.addEventListener('load', () => {
        // Request fullscreen after page loads
        try {
          const elem = previewWindow.document.documentElement;
          if (elem.requestFullscreen) {
            elem.requestFullscreen();
          } else if (elem.webkitRequestFullscreen) {
            elem.webkitRequestFullscreen();
          } else if (elem.mozRequestFullScreen) {
            elem.mozRequestFullScreen();
          } else if (elem.msRequestFullscreen) {
            elem.msRequestFullscreen();
          }
        } catch (e) {
          // Fullscreen may be blocked, popup still works
          console.log('Fullscreen request blocked, using popup mode');
        }
      });
    }
  }

  // Element interaction handlers from SlideRenderer
  function handleElementSelect(event) {
    const { element } = event.detail;
    // Background elements cannot be selected
    if (element.type === 'background') return;
    selectedElementId = element.id;
  }

  function handleBackgroundClick() {
    selectedElementId = null;
  }

  // Drag and resize handlers
  function startDrag(e, element) {
    // Background elements cannot be dragged
    if (element.type === 'background') return;
    
    if (e.target.dataset.handle) {
      startResize(e, element, e.target.dataset.handle);
      return;
    }
    
    isDragging = true;
    originalElement = JSON.parse(JSON.stringify(element));
    
    const rect = e.currentTarget.getBoundingClientRect();
    const containerRect = canvasContainer.getBoundingClientRect();
    
    dragStart = {
      mouseX: e.clientX,
      mouseY: e.clientY,
      elementX: element.position.x,
      elementY: element.position.y
    };
    
    document.addEventListener('mousemove', handleDrag);
    document.addEventListener('mouseup', stopDrag);
  }

  function handleDrag(e) {
    if (!isDragging || !selectedElement) return;
    
    const deltaX = (e.clientX - dragStart.mouseX) / canvasZoom;
    const deltaY = (e.clientY - dragStart.mouseY) / canvasZoom;
    
    const slide = getCurrentSlide();
    const el = slide.elements.find(el => el.id === selectedElementId);
    if (el) {
      el.position.x = Math.round(dragStart.elementX + deltaX);
      el.position.y = Math.round(dragStart.elementY + deltaY);
      cast = { ...cast };
    }
  }

  function stopDrag() {
    // Only push history if position actually changed
    if (isDragging && originalElement && selectedElement) {
      const moved = originalElement.position.x !== selectedElement.position.x || 
                    originalElement.position.y !== selectedElement.position.y;
      if (moved) {
        const name = selectedElement.name || selectedElement.type;
        pushHistory(`Move "${name}"`);
        // Auto-run widget after drag completes
        scheduleWidgetAutoRun(selectedElement);
      }
    }
    
    isDragging = false;
    document.removeEventListener('mousemove', handleDrag);
    document.removeEventListener('mouseup', stopDrag);
    
    // Sync ALL changes to inherited copies if this is a scoped nav
    const el = selectedElement;
    if (el?.type === 'nav' && el.scope !== 'slide' && !el._isInheritedCopy) {
      syncNavChanges(el);
    }
  }

  function startResize(e, element, handle) {
    e.stopPropagation();
    isResizing = true;
    resizeHandle = handle;
    originalElement = JSON.parse(JSON.stringify(element));
    
    dragStart = {
      mouseX: e.clientX,
      mouseY: e.clientY
    };
    
    document.addEventListener('mousemove', handleResizeDrag);
    document.addEventListener('mouseup', stopResize);
  }

  function handleResizeDrag(e) {
    if (!isResizing || !originalElement) return;
    
    const deltaX = (e.clientX - dragStart.mouseX) / canvasZoom;
    const deltaY = (e.clientY - dragStart.mouseY) / canvasZoom;
    
    const slide = getCurrentSlide();
    const el = slide.elements.find(el => el.id === selectedElementId);
    if (!el) return;
    
    const orig = originalElement;
    
    switch (resizeHandle) {
      case 'se':
        el.size.width = Math.max(20, orig.size.width + deltaX);
        el.size.height = Math.max(20, orig.size.height + deltaY);
        break;
      case 'sw':
        el.position.x = orig.position.x + deltaX;
        el.size.width = Math.max(20, orig.size.width - deltaX);
        el.size.height = Math.max(20, orig.size.height + deltaY);
        break;
      case 'ne':
        el.position.y = orig.position.y + deltaY;
        el.size.width = Math.max(20, orig.size.width + deltaX);
        el.size.height = Math.max(20, orig.size.height - deltaY);
        break;
      case 'nw':
        el.position.x = orig.position.x + deltaX;
        el.position.y = orig.position.y + deltaY;
        el.size.width = Math.max(20, orig.size.width - deltaX);
        el.size.height = Math.max(20, orig.size.height - deltaY);
        break;
      case 'n':
        el.position.y = orig.position.y + deltaY;
        el.size.height = Math.max(20, orig.size.height - deltaY);
        break;
      case 's':
        el.size.height = Math.max(20, orig.size.height + deltaY);
        break;
      case 'e':
        el.size.width = Math.max(20, orig.size.width + deltaX);
        break;
      case 'w':
        el.position.x = orig.position.x + deltaX;
        el.size.width = Math.max(20, orig.size.width - deltaX);
        break;
    }
    
    el.position.x = Math.round(el.position.x);
    el.position.y = Math.round(el.position.y);
    el.size.width = Math.round(el.size.width);
    el.size.height = Math.round(el.size.height);
    
    cast = { ...cast };
  }

  function stopResize() {
    // Only push history if size actually changed
    if (isResizing && originalElement && selectedElement) {
      const resized = originalElement.size.width !== selectedElement.size.width || 
                      originalElement.size.height !== selectedElement.size.height;
      if (resized) {
        const name = selectedElement.name || selectedElement.type;
        pushHistory(`Resize "${name}"`);
        // Auto-run widget after resize completes
        scheduleWidgetAutoRun(selectedElement);
      }
    }
    
    isResizing = false;
    resizeHandle = null;
    document.removeEventListener('mousemove', handleResizeDrag);
    document.removeEventListener('mouseup', stopResize);
    
    // Sync ALL changes to inherited copies if this is a scoped nav
    const el = selectedElement;
    if (el?.type === 'nav' && el.scope !== 'slide' && !el._isInheritedCopy) {
      syncNavChanges(el);
    }
  }

  // Layer management
  function moveLayerUp() {
    if (!selectedElement) return;
    const slide = getCurrentSlide();
    const index = slide.elements.findIndex(el => el.id === selectedElementId);
    if (index < slide.elements.length - 1) {
      const name = selectedElement.name || selectedElement.type;
      const temp = slide.elements[index];
      slide.elements[index] = slide.elements[index + 1];
      slide.elements[index + 1] = temp;
      slide.elements.forEach((el, i) => el.zIndex = i);
      cast = { ...cast };
      pushHistory(`Move "${name}" layer up`);
    }
  }

  function moveLayerDown() {
    if (!selectedElement) return;
    const slide = getCurrentSlide();
    const index = slide.elements.findIndex(el => el.id === selectedElementId);
    if (index > 0) {
      const name = selectedElement.name || selectedElement.type;
      const temp = slide.elements[index];
      slide.elements[index] = slide.elements[index - 1];
      slide.elements[index - 1] = temp;
      slide.elements.forEach((el, i) => el.zIndex = i);
      cast = { ...cast };
      pushHistory(`Move "${name}" layer down`);
    }
  }

  function moveLayerToTop() {
    if (!selectedElement) return;
    const name = selectedElement.name || selectedElement.type;
    const slide = getCurrentSlide();
    const index = slide.elements.findIndex(el => el.id === selectedElementId);
    const [element] = slide.elements.splice(index, 1);
    slide.elements.push(element);
    slide.elements.forEach((el, i) => el.zIndex = i);
    cast = { ...cast };
    pushHistory(`Move "${name}" to top`);
  }

  function moveLayerToBottom() {
    if (!selectedElement) return;
    const name = selectedElement.name || selectedElement.type;
    const slide = getCurrentSlide();
    const index = slide.elements.findIndex(el => el.id === selectedElementId);
    const [element] = slide.elements.splice(index, 1);
    slide.elements.unshift(element);
    slide.elements.forEach((el, i) => el.zIndex = i);
    cast = { ...cast };
    pushHistory(`Move "${name}" to bottom`);
  }

  // Update QR data helper
  function updateQRData() {
    if (!selectedElement || selectedElement.type !== 'qrcode') return;
    
    const el = selectedElement;
    switch (el.qrType) {
      case 'url':
        el.data = el.qrUrl || 'https://example.com';
        break;
      case 'text':
        el.data = el.qrText || 'Hello';
        break;
      case 'wifi':
        const hidden = el.qrWifiHidden ? 'true' : 'false';
        el.data = `WIFI:T:${el.qrWifiEncryption || 'WPA'};S:${el.qrWifiSsid || ''};P:${el.qrWifiPassword || ''};H:${hidden};;`;
        break;
      case 'email':
        const subject = el.qrEmailSubject ? `?subject=${encodeURIComponent(el.qrEmailSubject)}` : '';
        el.data = `mailto:${el.qrEmail || ''}${subject}`;
        break;
      case 'phone':
        el.data = `tel:${el.qrPhone || ''}`;
        break;
      case 'sms':
        const body = el.qrSmsMessage ? `?body=${encodeURIComponent(el.qrSmsMessage)}` : '';
        el.data = `sms:${el.qrSmsPhone || ''}${body}`;
        break;
    }
    cast = { ...cast };
  }
</script>

<svelte:head>
  <title>Slidecast Studio - {cast?.name || 'Loading...'}</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <!-- Roku-Compatible Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto:wght@400;500;700&family=Open+Sans:wght@400;600;700&family=Poppins:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&family=Lato:wght@400;700&family=Nunito:wght@400;600;700&family=Work+Sans:wght@400;500;600;700&family=Playfair+Display:wght@400;600;700&family=Merriweather:wght@400;700&family=Lora:wght@400;600;700&family=Libre+Baskerville:wght@400;700&family=JetBrains+Mono:wght@400;500;600;700&family=Fira+Code:wght@400;500;600;700&family=Source+Code+Pro:wght@400;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&family=Roboto+Mono:wght@400;500;700&family=Bebas+Neue&family=Oswald:wght@400;500;600;700&family=Raleway:wght@400;500;600;700&family=Anton&family=Abril+Fatface&family=Righteous&family=Dancing+Script:wght@400;700&family=Pacifico&family=Satisfy&display=swap" rel="stylesheet" />
</svelte:head>

{#if loading}
  <div class="loading-fullscreen">
    <div class="spinner"></div>
    <span>Loading Studio...</span>
  </div>
{:else}
<div class="studio-container">
  <!-- Header with Menu Bar -->
  <header class="studio-header">
    <!-- Top Row: Menu Bar -->
    <div class="menu-bar-row">
      <div class="menu-bar-left">
        <button class="back-btn" on:click={() => handleMenuAction('close')} title="Back to Dashboard">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
        </button>
        
        <nav class="menu-bar">
          {#each Object.entries(menuDefinitions) as [key, menu]}
            <div class="menu-item" class:open={openMenu === key}>
              <button 
                class="menu-trigger" 
                on:click|stopPropagation={() => toggleMenu(key)}
                on:mouseenter={() => openMenu && (openMenu = key)}
              >
                {menu.label}
              </button>
              
              {#if openMenu === key}
                <div class="menu-dropdown">
                  {#each menu.items as item}
                    {#if item.type === 'separator'}
                      <div class="menu-separator"></div>
                    {:else if item.submenu}
                      <div class="menu-item-with-submenu">
                        <button class="menu-dropdown-item has-submenu" disabled={item.disabled?.()}>
                          {#if item.icon}<i class={item.icon}></i>{/if}
                          <span>{item.label}</span>
                          <i class="fa-solid fa-chevron-right submenu-arrow"></i>
                        </button>
                        <div class="submenu">
                          {#each item.submenu as subitem}
                            {#if subitem.type === 'separator'}
                              <div class="menu-separator"></div>
                            {:else}
                              <button 
                                class="menu-dropdown-item" 
                                on:click={() => handleMenuAction(subitem.action)}
                                disabled={subitem.disabled?.()}
                              >
                                <span>{subitem.label}</span>
                                {#if subitem.shortcut}<span class="menu-shortcut">{subitem.shortcut}</span>{/if}
                              </button>
                            {/if}
                          {/each}
                        </div>
                      </div>
                    {:else}
                      <button 
                        class="menu-dropdown-item" 
                        class:has-check={item.checked}
                        on:click={() => handleMenuAction(item.action)}
                        disabled={item.disabled?.()}
                      >
                        {#if item.checked}
                          <i class="fa-solid fa-check menu-check" class:visible={item.checked()}></i>
                        {/if}
                        {#if item.icon}<i class={item.icon}></i>{/if}
                        <span>{item.label}</span>
                        {#if item.shortcut}<span class="menu-shortcut">{item.shortcut}</span>{/if}
                      </button>
                    {/if}
                  {/each}
                </div>
              {/if}
            </div>
          {/each}
        </nav>
      </div>
      
      <div class="menu-bar-right">
        <button class="btn btn-ghost btn-sm" on:click={openBrowserPreview} title="Preview Cast">
          <i class="fa-solid fa-play"></i>
          Preview
        </button>
        <button class="btn btn-primary btn-sm" class:has-changes={hasUnsavedChanges} on:click={saveCast} disabled={saving}>
          {#if saving}
            <span class="spinner-sm"></span>
          {:else}
            <i class="fa-solid fa-floppy-disk"></i>
          {/if}
          Save
          {#if hasUnsavedChanges}<span class="unsaved-dot">•</span>{/if}
        </button>
      </div>
    </div>
    
    <!-- Second Row: Document Title & Status -->
    <div class="title-bar-row">
      <div class="title-bar-left">
        <input type="text" class="cast-name-input" bind:value={cast.name} placeholder="Untitled Cast" />
        {#if hasUnsavedChanges}
          <span class="unsaved-indicator">Unsaved changes</span>
        {/if}
      </div>
      
      <div class="title-bar-right">
        <span class="canvas-size" on:click={() => showCanvasSizeModal = true} title="Canvas Size">
          <i class="fa-solid fa-expand"></i>
          1920 × 1080
        </span>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <div class="studio-main">
    <!-- Slides Panel -->
    <!-- Slides Panel -->
    <SlidesPanel
      {cast}
      {currentGroupId}
      {currentSlideIndex}
      currentGroup={getCurrentGroup()}
      {currentSlides}
      {slideClipboard}
      {clipboardOperation}
      {draggedSlideIndex}
      {dragOverSlideIndex}
      collapsed={slidesPanelCollapsed}
      on:selectGroup={(e) => selectGroup(e.detail)}
      on:deleteGroup={(e) => deleteGroup(e.detail)}
      on:addSlide={addSlide}
      on:selectSlide={(e) => selectSlide(e.detail)}
      on:deleteSlide={(e) => deleteSlide(e.detail)}
      on:duplicateSlide={(e) => duplicateSlide(e.detail)}
      on:copySlide={(e) => copySlide(e.detail)}
      on:cutSlide={(e) => cutSlide(e.detail)}
      on:openSlideSettings={(e) => { editingSlideIndex = e.detail; showSlideSettingsModal = true; }}
      on:openGroupSettings={() => showGroupSettingsModal = true}
      on:openAddGroupModal={() => showAddGroupModal = true}
      on:showPasteOptions={showPasteOptions}
      on:toggleCollapse={(e) => slidesPanelCollapsed = e.detail}
      on:slideDragStart={(e) => handleSlideDragStart(e.detail.event, e.detail.index)}
      on:slideDragOver={(e) => handleSlideDragOver(e.detail.event, e.detail.index)}
      on:slideDragLeave={(e) => handleSlideDragLeave(e.detail.event)}
      on:slideDrop={(e) => handleSlideDrop(e.detail.event, e.detail.index)}
      on:slideDragEnd={(e) => handleSlideDragEnd(e.detail.event)}
    />

    <!-- Canvas Area -->
    <main 
      class="canvas-area" 
      class:panning={isPanning}
      class:hand-tool={activeTool === 'hand'}
      bind:this={canvasContainer}
      on:wheel={handleCanvasWheel}
      on:mousedown={handleCanvasMouseDown}
      on:mousemove={handleCanvasPanMove}
      on:mouseup={handleCanvasPanEnd}
      on:mouseleave={handleCanvasPanEnd}
    >
      <!-- TV Frame -->
      <div class="tv-frame" style="transform: translate({canvasPan.x}px, {canvasPan.y}px) scale({canvasZoom}); transform-origin: center center;">
        <div class="tv-bezel">
          <div class="tv-brand">
            <span class="brand-logo">W</span>
            <span class="brand-name">waiveo</span>
          </div>
          <div class="canvas-wrapper">
        <!-- Slide Renderer -->
        <SlideRenderer
          slide={currentSlide}
          variables={cast?.definition?.variables || {}}
          scale={1}
          width={1920}
          height={1080}
          editMode={true}
          selectedElementId={selectedElementId}
          showGrid={true}
          {currentGroupId}
          {currentSlideIndex}
          on:elementSelect={handleElementSelect}
          on:backgroundClick={handleBackgroundClick}
        />
        
        <!-- Drag overlay for selected element -->
        {#if selectedElement}
          <div 
            class="element-drag-overlay"
            class:no-resize={selectedElement.type === 'widget'}
            style="
              left: {selectedElement.position.x}px;
              top: {selectedElement.position.y}px;
              width: {selectedElement.size.width}px;
              height: {selectedElement.size.height}px;
              {selectedElement.style?.rotation ? `transform: rotate(${selectedElement.style.rotation}deg); transform-origin: center center;` : ''}
            "
            on:mousedown={(e) => startDrag(e, selectedElement)}
          >
            <!-- Hide resize handles for widgets - size controlled via widget config -->
            {#if selectedElement.type !== 'widget'}
              <div class="handle handle-nw" data-handle="nw"></div>
              <div class="handle handle-n" data-handle="n"></div>
              <div class="handle handle-ne" data-handle="ne"></div>
              <div class="handle handle-e" data-handle="e"></div>
              <div class="handle handle-se" data-handle="se"></div>
              <div class="handle handle-s" data-handle="s"></div>
              <div class="handle handle-sw" data-handle="sw"></div>
              <div class="handle handle-w" data-handle="w"></div>
            {/if}
            
            <!-- Floating widget toolbar -->
            {#if selectedElement.type === 'widget'}
              {@const widgetInfo = availableWidgets.find(w => w.uuid === selectedElement.widgetUuid)}
              <div class="widget-floating-toolbar" on:mousedown|stopPropagation>
                <button class="widget-toolbar-btn primary" on:click={() => openWidgetConfig(selectedElement)} title="Configure Widget">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
                  Configure
                </button>
                <span class="widget-toolbar-name">{widgetInfo?.name || selectedElement.widgetName || 'Widget'}</span>
              </div>
            {/if}
            
            <!-- Floating text toolbar -->
            {#if selectedElement.type === 'text'}
              <div class="widget-floating-toolbar" on:mousedown|stopPropagation>
                <button class="widget-toolbar-btn primary" on:click={() => openTextConfig(selectedElement)} title="Edit Text">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                  Edit Text
                </button>
                <span class="widget-toolbar-name">{selectedElement.content?.substring(0, 20) || 'Text'}{selectedElement.content?.length > 20 ? '...' : ''}</span>
              </div>
            {/if}
            
            <!-- Floating nav toolbar -->
            {#if selectedElement.type === 'nav'}
              <div class="widget-floating-toolbar" on:mousedown|stopPropagation>
                <button class="widget-toolbar-btn primary" on:click={() => openNavConfig(selectedElement)} title="Edit Nav Menu">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
                  Edit Nav
                </button>
                <span class="widget-toolbar-name">{selectedElement.items?.length || 0} items</span>
              </div>
            {/if}
            
            <!-- Floating QR toolbar -->
            {#if selectedElement.type === 'qrcode'}
              <div class="widget-floating-toolbar" on:mousedown|stopPropagation>
                <button class="widget-toolbar-btn primary" on:click={() => openQRConfig(selectedElement)} title="Edit QR Code">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 11h8V3H3v8zm2-6h4v4H5V5zm8-2v8h8V3h-8zm6 6h-4V5h4v4zM3 21h8v-8H3v8zm2-6h4v4H5v-4zm13 0h1v1h-1zm-3-1h2v2h-2zm-1 2h1v4h-4v-2h1v-1h2zm4-1h2v4h-1v-3h-1zm-3 4h1v1h-1zm2 0h1v1h-1z"/></svg>
                  Edit QR
                </button>
                <span class="widget-toolbar-name">{selectedElement.qrType === 'wifi' ? 'WiFi' : selectedElement.qrType === 'text' ? 'Text' : 'URL'}</span>
              </div>
            {/if}
          </div>
        {/if}
        
        <!-- Widget slow loading spinners (shown below widget after 500ms) -->
        {#if currentSlide?.elements}
          {#each currentSlide.elements.filter(el => el.type === 'widget' && slowLoadingWidgets.has(el.id)) as widget}
            <div 
              class="widget-loading-indicator"
              style="
                left: {widget.position.x}px;
                top: {widget.position.y + widget.size.height + 8}px;
                width: {widget.size.width}px;
              "
            >
              <div class="loading-spinner-small"></div>
              <span>Rendering widget...</span>
            </div>
          {/each}
        {/if}
        </div>
          <div class="tv-led"></div>
        </div>
        <div class="tv-stand">
          <div class="stand-neck"></div>
          <div class="stand-base"></div>
        </div>
      </div>
    </main>

    <!-- Right Sidebar: Layers + Properties -->
    <aside class="right-sidebar" class:collapsed={rightSidebarCollapsed} style="width: {rightSidebarCollapsed ? '40px' : rightSidebarWidth + 'px'}">
      <!-- Resize Handle -->
      {#if !rightSidebarCollapsed}
        <div class="sidebar-resize-handle" on:mousedown={startSidebarResize}></div>
      {/if}
      <!-- Collapse Toggle -->
      <button class="sidebar-collapse-btn" on:click={toggleRightSidebar} title={rightSidebarCollapsed ? 'Expand Panel' : 'Collapse Panel'}>
        <svg viewBox="0 0 24 24" fill="currentColor" style="transform: rotate({rightSidebarCollapsed ? '180deg' : '0deg'})"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
      </button>
      <!-- Layers Panel -->
      <LayersPanel
        {currentSlide}
        {selectedElementId}
        {draggedLayerId}
        {dragOverLayerId}
        collapsed={layersPanelCollapsed}
        on:selectElement={(e) => selectedElementId = e.detail}
        on:duplicateElement={(e) => duplicateElement(e.detail)}
        on:deleteElement={(e) => deleteElement(e.detail)}
        on:updateElementName={() => { cast = cast; trackPropertyChange('Rename layer'); }}
        on:toggleCollapse={(e) => layersPanelCollapsed = e.detail}
        on:layerDragStart={(e) => handleLayerDragStart(e.detail.event, e.detail.element)}
        on:layerDragOver={(e) => handleLayerDragOver(e.detail.event, e.detail.element)}
        on:layerDragLeave={(e) => handleLayerDragLeave(e.detail.event)}
        on:layerDrop={(e) => handleLayerDrop(e.detail.event, e.detail.element)}
        on:layerDragEnd={(e) => handleLayerDragEnd(e.detail.event)}
      />

      <!-- History Panel -->
      <HistoryPanel
        {historyStack}
        {historyIndex}
        show={showHistoryPanel}
        collapsed={historyPanelCollapsed}
        on:jumpToHistory={(e) => jumpToHistory(e.detail)}
        on:toggleCollapse={(e) => historyPanelCollapsed = e.detail}
      />

    <!-- Properties Panel -->
      <div class="right-panel properties-panel" class:collapsed={propertiesPanelCollapsed}>
        <div class="panel-header" on:click={() => propertiesPanelCollapsed = !propertiesPanelCollapsed}>
          <h3>{selectedElement?.name || (selectedElement ? selectedElement.type.charAt(0).toUpperCase() + selectedElement.type.slice(1) : 'Properties')}</h3>
          <div class="panel-actions">
            {#if selectedElement && !propertiesPanelCollapsed && selectedElement.type !== 'background'}
              <button class="icon-btn" title="Duplicate" on:click|stopPropagation={duplicateSelectedElement}><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg></button>
              <button class="icon-btn danger" title="Delete" on:click|stopPropagation={deleteSelectedElement}><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg></button>
            {/if}
            <button class="icon-btn">{propertiesPanelCollapsed ? '‹' : '›'}</button>
          </div>
        </div>
        {#if !propertiesPanelCollapsed}
        <div class="panel-content">
          {#if selectedElement}
        <div class="properties-content">
          <!-- Position (not for background) -->
          <!-- Background properties -->
          {#if selectedElement.type === 'background'}
          <div class="prop-group">
            <h4>Background</h4>
            <div class="prop-row">
              <label>Color</label>
              <input type="color" bind:value={selectedElement.style.backgroundColor} on:input={() => {
                // Mark as custom background and update the slide's backgroundColor
                if (currentSlide) {
                  currentSlide._hasCustomBackground = true;
                  currentSlide.backgroundColor = selectedElement.style.backgroundColor;
                }
                onElementChange('background color');
              }} />
            </div>
          </div>
          {/if}

          {#if selectedElement.type !== 'background'}
          <div class="prop-group">
            <h4>Position</h4>
            <div class="prop-row">
              <label>X</label>
              <input 
                type="number" 
                bind:value={selectedElement.position.x} 
                on:input={() => onElementChange('position')}
              />
            </div>
            <div class="prop-row">
              <label>Y</label>
              <input 
                type="number" 
                bind:value={selectedElement.position.y} 
                on:input={() => onElementChange('position')}
              />
            </div>
          </div>
          
          <!-- Size (hidden for widgets - controlled by widget config) -->
          {#if selectedElement.type !== 'widget'}
          <div class="prop-group">
            <h4>Size</h4>
            <div class="prop-row">
              <label>W</label>
              <input 
                type="number" 
                bind:value={selectedElement.size.width} 
                on:input={() => onElementChange('size')}
              />
            </div>
            <div class="prop-row">
              <label>H</label>
              <input 
                type="number" 
                bind:value={selectedElement.size.height} 
                on:input={() => onElementChange('size')}
              />
            </div>
          </div>
          {/if}
          
          <!-- Transforms (for all non-background elements) -->
          <div class="prop-group">
            <h4>Transforms</h4>
            
            <!-- Rotation -->
            <div class="prop-row">
              <label>Rotation</label>
              <div class="slider-with-value">
                <input 
                  type="range" 
                  min="-180" 
                  max="180" 
                  step="1"
                  bind:value={selectedElement.style.rotation} 
                  on:input={() => { if (selectedElement.style.rotation === undefined) selectedElement.style.rotation = 0; onElementChange('rotation'); }}
                />
                <span class="slider-value">{selectedElement.style.rotation ?? 0}°</span>
              </div>
            </div>
            
            <!-- Scale -->
            <div class="prop-row">
              <label>Scale</label>
              <div class="slider-with-value">
                <input 
                  type="range" 
                  min="0.1" 
                  max="3" 
                  step="0.1"
                  bind:value={selectedElement.style.scale} 
                  on:input={() => { if (selectedElement.style.scale === undefined) selectedElement.style.scale = 1; onElementChange('scale'); }}
                />
                <span class="slider-value">{(selectedElement.style.scale ?? 1).toFixed(1)}×</span>
              </div>
            </div>
            
            <!-- Flip -->
            <div class="prop-row">
              <label>Flip</label>
              <div class="btn-group">
                <button 
                  class="flip-btn" 
                  class:active={selectedElement.style.flipX}
                  on:click={() => { selectedElement.style.flipX = !selectedElement.style.flipX; onElementChange('flip horizontal'); }}
                  title="Flip Horizontal"
                >
                  <i class="fa-solid fa-left-right"></i>
                </button>
                <button 
                  class="flip-btn" 
                  class:active={selectedElement.style.flipY}
                  on:click={() => { selectedElement.style.flipY = !selectedElement.style.flipY; onElementChange('flip vertical'); }}
                  title="Flip Vertical"
                >
                  <i class="fa-solid fa-up-down"></i>
                </button>
              </div>
            </div>
            
            <!-- Opacity -->
            <div class="prop-row">
              <label>Opacity</label>
              <div class="slider-with-value">
                <input 
                  type="range" 
                  min="0" 
                  max="1" 
                  step="0.05"
                  bind:value={selectedElement.style.opacity} 
                  on:input={() => onElementChange('opacity')}
                />
                <span class="slider-value">{Math.round((selectedElement.style.opacity ?? 1) * 100)}%</span>
              </div>
            </div>
            
            <!-- Blur -->
            <div class="prop-row">
              <label>Blur</label>
              <div class="slider-with-value">
                <input 
                  type="range" 
                  min="0" 
                  max="50" 
                  step="1"
                  bind:value={selectedElement.style.blur} 
                  on:input={() => onElementChange('blur')}
                />
                <span class="slider-value">{selectedElement.style.blur ?? 0}px</span>
              </div>
            </div>
          </div>
          
          <!-- Opacity Gradient / Mask -->
          <div class="prop-group collapsible" class:collapsed={!selectedElement.style?.gradientMaskEnabled}>
            <h4 class="collapsible-header" on:click={() => { selectedElement.style.gradientMaskEnabled = !selectedElement.style.gradientMaskEnabled; cast = cast; pushHistory(`Toggle opacity gradient on "${selectedElement?.name || selectedElement?.type}"`); }}>
              <span class="collapse-icon">{selectedElement.style?.gradientMaskEnabled ? '▼' : '▶'}</span>
              Opacity Gradient
              <label class="toggle-switch small" on:click|stopPropagation>
                <input 
                  type="checkbox" 
                  bind:checked={selectedElement.style.gradientMaskEnabled} 
                  on:change={() => cast = cast}
                />
                <span class="toggle-slider"></span>
              </label>
            </h4>
            {#if selectedElement.style?.gradientMaskEnabled}
              <div class="prop-row">
                <label>Direction</label>
                <select bind:value={selectedElement.style.gradientDirection} on:change={() => cast = cast}>
                  <option value="to-right">Left → Right</option>
                  <option value="to-left">Right → Left</option>
                  <option value="to-bottom">Top → Bottom</option>
                  <option value="to-top">Bottom → Top</option>
                  <option value="to-bottom-right">Top-Left → Bottom-Right</option>
                  <option value="to-bottom-left">Top-Right → Bottom-Left</option>
                  <option value="radial-out">Center → Edges</option>
                  <option value="radial-in">Edges → Center</option>
                </select>
              </div>
              <div class="prop-row">
                <label>Start</label>
                <div class="slider-with-value">
                  <input 
                    type="range" 
                    min="0" 
                    max="100" 
                    step="5"
                    bind:value={selectedElement.style.gradientStart} 
                    on:input={() => cast = cast}
                  />
                  <span class="slider-value">{selectedElement.style.gradientStart ?? 0}%</span>
                </div>
              </div>
              <div class="prop-row">
                <label>End</label>
                <div class="slider-with-value">
                  <input 
                    type="range" 
                    min="0" 
                    max="100" 
                    step="5"
                    bind:value={selectedElement.style.gradientEnd} 
                    on:input={() => cast = cast}
                  />
                  <span class="slider-value">{selectedElement.style.gradientEnd ?? 100}%</span>
                </div>
              </div>
            {/if}
          </div>
          {/if}

          <!-- Text properties (simplified - main editing in floating window) -->
          {#if selectedElement.type === 'text'}
            <div class="prop-group">
              <h4>Text</h4>
              <div class="widget-info-compact">
                <span class="widget-icon">📝</span>
                <div class="widget-meta">
                  <span class="widget-name">{selectedElement.content?.substring(0, 25) || 'Text'}{selectedElement.content?.length > 25 ? '...' : ''}</span>
                  <span class="widget-type">{selectedElement.style?.fontFamily || 'Inter'} • {selectedElement.style?.fontSize || 24}px</span>
                </div>
                <button class="widget-config-btn" on:click={() => openTextConfig(selectedElement)} title="Edit Text">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                </button>
              </div>
            </div>
            
            <!-- Layer Properties -->
            <div class="prop-group">
              <h4>Layer</h4>
              <div class="prop-row">
                <label>Opacity</label>
                <div class="slider-with-value">
                  <input 
                    type="range" 
                    min="0" 
                    max="1" 
                    step="0.1" 
                    bind:value={selectedElement.style.opacity} 
                    on:input={() => onElementChange('text opacity')}
                  />
                  <span class="slider-value">{Math.round((selectedElement.style.opacity ?? 1) * 100)}%</span>
                </div>
              </div>
            </div>
          {/if}

          <!-- Shape properties -->
          {#if selectedElement.type === 'shape'}
            <div class="prop-group">
              <h4>Shape</h4>
              <div class="prop-row">
                <label>Type</label>
                <select bind:value={selectedElement.shape} on:change={() => { cast = cast; pushHistory(`Change shape type to "${selectedElement.shape}"`); }}>
                  <option value="rectangle">Rectangle</option>
                  <option value="circle">Circle</option>
                </select>
              </div>
              <div class="prop-row">
                <label>Fill</label>
                <input type="color" bind:value={selectedElement.style.fill} on:input={() => onElementChange('fill color')} />
              </div>
              <div class="prop-row">
                  <label>Radius</label>
                <div class="slider-with-value">
                <input 
                    type="range"
                    min="0"
                    max="100"
                    step="1"
                  bind:value={selectedElement.style.borderRadius} 
                    on:input={() => onElementChange('border radius')}
                  />
                  <span class="slider-value">{selectedElement.style.borderRadius ?? 0}px</span>
                </div>
                </div>
              <div class="prop-row">
                <label>Opacity</label>
                <div class="slider-with-value">
                  <input 
                    type="range" 
                    min="0" 
                    max="1" 
                    step="0.1" 
                    bind:value={selectedElement.style.opacity} 
                    on:input={() => onElementChange('shape opacity')}
                  />
                  <span class="slider-value">{Math.round((selectedElement.style.opacity ?? 1) * 100)}%</span>
                </div>
                </div>
            </div>
          {/if}

          <!-- Image properties -->
          {#if selectedElement.type === 'image'}
            <div class="prop-group">
              <h4>Image</h4>
              <button class="btn btn-secondary btn-sm" on:click={() => showMediaModal = true}>Change Image</button>
              <div class="prop-row">
                <label>Fit</label>
                <select bind:value={selectedElement.style.objectFit} on:change={() => { cast = cast; pushHistory(`Change image fit to "${selectedElement.style.objectFit}"`); }}>
                  <option value="cover">Cover</option>
                  <option value="contain">Contain</option>
                  <option value="fill">Fill</option>
                </select>
              </div>
              <div class="prop-row">
                <label>Opacity</label>
                <div class="slider-with-value">
                  <input 
                    type="range" 
                    min="0" 
                    max="1" 
                    step="0.1" 
                    bind:value={selectedElement.style.opacity} 
                    on:input={() => onElementChange('image opacity')}
                  />
                  <span class="slider-value">{Math.round((selectedElement.style.opacity ?? 1) * 100)}%</span>
                </div>
              </div>
              <div class="prop-row">
                <label>Radius</label>
                <div class="slider-with-value">
                <input 
                    type="range"
                    min="0"
                    max="100"
                    step="1"
                  bind:value={selectedElement.style.borderRadius} 
                    on:input={() => onElementChange('border radius')}
                  />
                  <span class="slider-value">{selectedElement.style.borderRadius ?? 0}px</span>
                </div>
              </div>
            </div>
          {/if}

          <!-- Widget properties (simplified - config in modal) -->
          {#if selectedElement.type === 'widget'}
            {@const widget = availableWidgets.find(w => w.uuid === selectedElement.widgetUuid)}
            <div class="prop-group">
              <h4>Widget</h4>
              
              <!-- Widget Info Card -->
              <div class="widget-info-card">
                <div class="widget-info-icon">{widget?.icon || '📦'}</div>
                <div class="widget-info-details">
                  <span class="widget-info-name">{widget?.name || selectedElement.widgetName || 'Widget'}</span>
                  <span class="widget-info-category">{widget?.category || 'custom'}</span>
                </div>
                <button class="widget-config-btn" on:click={() => openWidgetConfig(selectedElement)} title="Configure Widget">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
                </button>
              </div>
              
              <!-- Widget Error Display -->
              {#if selectedElement._widgetError}
                <div class="widget-error-display">
                  <span class="error-icon">⚠️</span>
                  <span class="error-text">{selectedElement._widgetError}</span>
                </div>
              {/if}
            </div>
            
            <!-- Layer Properties (same as other elements) -->
            <div class="prop-group">
              <h4>Layer</h4>
              <div class="prop-row">
                <label>Opacity</label>
                <div class="slider-with-value">
                  <input 
                    type="range" 
                    min="0" 
                    max="1" 
                    step="0.1" 
                    bind:value={selectedElement.style.opacity} 
                    on:input={() => onElementChange('widget opacity')}
                  />
                  <span class="slider-value">{Math.round((selectedElement.style.opacity ?? 1) * 100)}%</span>
                </div>
              </div>
            </div>
          {/if}

          <!-- Nav properties (simplified - full config in floating window) -->
          {#if selectedElement.type === 'nav'}
            <!-- Info Card -->
            <div class="prop-group">
              <div class="widget-info-card" on:click={() => openNavConfig(selectedElement)}>
                <span class="widget-icon">☰</span>
                <div class="widget-meta">
                  <span class="widget-name">{selectedElement.name || 'Navigation Menu'}</span>
                  <span class="widget-type">{selectedElement.items?.length || 0} items • {selectedElement.layout || 'horizontal'}</span>
                </div>
                <button class="widget-config-btn" on:click|stopPropagation={() => openNavConfig(selectedElement)} title="Edit Navigation">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.08-.47-.12-.61l-2.03-1.58z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </div>
            </div>
            
            <!-- Scope Badge -->
            {#if selectedElement._isInheritedCopy}
              <div class="prop-group">
                <div class="scope-info-badge inherited">
                  🔗 Inherited from {selectedElement.scope === 'cast' ? 'cast' : 'group'}
                </div>
              </div>
            {:else if selectedElement.scope === 'cast'}
              <div class="prop-group">
                <div class="scope-info-badge cast">🌐 Applied to entire cast</div>
              </div>
            {:else if selectedElement.scope === 'group'}
              <div class="prop-group">
                <div class="scope-info-badge group">📁 Applied to group</div>
              </div>
            {/if}
            
            <!-- Layer Properties -->
            <div class="prop-group">
              <h4>Layer</h4>
              <div class="prop-row">
                <label>Opacity</label>
                <div class="slider-with-value">
                  <input 
                    type="range" 
                    min="0" 
                    max="1" 
                    step="0.1" 
                    bind:value={selectedElement.style.opacity} 
                    on:input={() => { cast = { ...cast }; syncNavChanges(selectedElement); }}
                  />
                  <span class="slider-value">{Math.round((selectedElement.style.opacity ?? 1) * 100)}%</span>
                </div>
              </div>
            </div>
          {/if}
          
          <!-- Nav properties REMOVED - now in floating window -->
          {#if false && selectedElement.type === 'nav-old'}
            <!-- OLD Style Preset - kept for reference -->
            <div class="prop-group nav-preset-group">
              <h4>Quick Style</h4>
              <div class="nav-presets">
                <button class="nav-preset-btn" class:active={selectedElement.style?.preset === 'unified-bar'} 
                  on:click={() => {
                    selectedElement.style = {
                      ...selectedElement.style,
                      preset: 'unified-bar',
                      containerBackground: '#000000',
                      containerOpacity: 0.6,
                      containerRadius: 16,
                      containerPadding: 8,
                      itemBackgroundColor: '#ffffff',
                      itemBackgroundOpacity: 0,
                      itemBorderRadius: 8,
                      itemPadding: 12,
                      itemGap: 4
                    };
                    cast = { ...cast };
                  }} title="Unified Bar">
                  <span class="preset-icon">▬</span>
                  <span>Bar</span>
                </button>
                <button class="nav-preset-btn" class:active={selectedElement.style?.preset === 'pill-buttons'}
                  on:click={() => {
                    selectedElement.style = {
                      ...selectedElement.style,
                      preset: 'pill-buttons',
                      containerBackground: '#000000',
                      containerOpacity: 0,
                      containerRadius: 0,
                      containerPadding: 0,
                      itemBackgroundColor: '#333333',
                      itemBackgroundOpacity: 0.8,
                      itemBorderRadius: 50,
                      itemPadding: 14,
                      itemGap: 12
                    };
                    cast = { ...cast };
                  }} title="Pill Buttons">
                  <span class="preset-icon">◉</span>
                  <span>Pills</span>
                </button>
                <button class="nav-preset-btn" class:active={selectedElement.style?.preset === 'contained-pills'}
                  on:click={() => {
                    selectedElement.style = {
                      ...selectedElement.style,
                      preset: 'contained-pills',
                      containerBackground: '#1a1a2e',
                      containerOpacity: 0.9,
                      containerRadius: 20,
                      containerPadding: 10,
                      itemBackgroundColor: '#ffffff',
                      itemBackgroundOpacity: 0.1,
                      itemBorderRadius: 12,
                      itemPadding: 12,
                      itemGap: 8
                    };
                    cast = { ...cast };
                  }} title="Contained Pills">
                  <span class="preset-icon">▭</span>
                  <span>Tray</span>
                </button>
                <button class="nav-preset-btn" class:active={selectedElement.style?.preset === 'minimal'}
                  on:click={() => {
                    selectedElement.style = {
                      ...selectedElement.style,
                      preset: 'minimal',
                      containerBackground: '#000000',
                      containerOpacity: 0,
                      containerRadius: 0,
                      containerPadding: 0,
                      itemBackgroundColor: '#ffffff',
                      itemBackgroundOpacity: 0,
                      itemBorderRadius: 4,
                      itemPadding: 10,
                      itemGap: 20
                    };
                    cast = { ...cast };
                  }} title="Minimal">
                  <span class="preset-icon">―</span>
                  <span>Minimal</span>
                </button>
                <button class="nav-preset-btn" class:active={selectedElement.style?.preset === 'glass'}
                  on:click={() => {
                    selectedElement.style = {
                      ...selectedElement.style,
                      preset: 'glass',
                      containerBackground: '#ffffff',
                      containerOpacity: 0.15,
                      containerRadius: 24,
                      containerPadding: 10,
                      containerBlur: 20,
                      itemBackgroundColor: '#ffffff',
                      itemBackgroundOpacity: 0.1,
                      itemBorderRadius: 14,
                      itemPadding: 14,
                      itemGap: 8
                    };
                    cast = { ...cast };
                  }} title="Glass">
                  <span class="preset-icon">◇</span>
                  <span>Glass</span>
                </button>
                <button class="nav-preset-btn" class:active={selectedElement.style?.preset === 'segmented'}
                  on:click={() => {
                    selectedElement.style = {
                      ...selectedElement.style,
                      preset: 'segmented',
                      containerBackground: '#333333',
                      containerOpacity: 0.9,
                      containerRadius: 10,
                      containerPadding: 4,
                      itemBackgroundColor: '#ffffff',
                      itemBackgroundOpacity: 0,
                      itemBorderRadius: 6,
                      itemPadding: 10,
                      itemGap: 2
                    };
                    cast = { ...cast };
                  }} title="Segmented">
                  <span class="preset-icon">▤</span>
                  <span>Segment</span>
                </button>
              </div>
            </div>

            <!-- Scope & Inheritance -->
            <div class="prop-group nav-scope-group">
              <h4>
                Scope
                {#if selectedElement._isInheritedCopy}
                  <span class="scope-badge inherited">🔗 Inherited</span>
                {:else if selectedElement.scope === 'cast'}
                  <span class="scope-badge cast">🌐 Cast</span>
                {:else if selectedElement.scope === 'group'}
                  <span class="scope-badge group">📁 Group</span>
                {/if}
              </h4>
              
              {#if selectedElement._isInheritedCopy}
                <!-- Inherited nav: show source info and actions -->
                <div class="inherited-nav-info">
                  <p class="scope-hint">This nav is inherited from another slide.</p>
                  <div class="inherited-actions">
                    <button class="scope-action-btn" on:click={() => goToNavSource(selectedElement)}>
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                      Edit Source
                    </button>
                    <button class="scope-action-btn" on:click={() => makeNavLocal(selectedElement)}>
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                      Make Local Copy
                    </button>
                  </div>
                  <div class="toggle-row">
                    <span>Show on this slide</span>
                    <label class="toggle-switch">
                    <input type="checkbox" 
                      checked={!currentSlide?.navOverrides?.[selectedElement._sourceNavId]?.hidden}
                      on:change={(e) => {
                        if (!currentSlide.navOverrides) currentSlide.navOverrides = {};
                        currentSlide.navOverrides[selectedElement._sourceNavId] = {
                          ...currentSlide.navOverrides[selectedElement._sourceNavId],
                          hidden: !e.target.checked
                        };
                        cast = { ...cast };
                      }}
                    />
                      <span class="toggle-slider"></span>
                  </label>
                  </div>
                </div>
              {:else}
                <!-- Source nav: show scope controls -->
                <div class="prop-row">
                  <label>Apply to</label>
                  <select value={selectedElement.scope || 'slide'} on:change={(e) => {
                    const oldScope = selectedElement.scope || 'slide';
                    const newScope = e.target.value;
                    selectedElement.scope = newScope;
                    // When switching to group scope, set sourceGroupId to current group
                    if (newScope === 'group') {
                      selectedElement.sourceGroupId = currentGroupId;
                    }
                    propagateNavToScope(selectedElement, newScope, oldScope);
                    cast = { ...cast };
                  }}>
                    <option value="slide">This Slide Only</option>
                    <option value="group">All Slides in Group</option>
                    <option value="cast">All Slides in Cast</option>
                  </select>
                </div>
                
                {#if selectedElement.scope === 'group'}
                  <div class="prop-row">
                    <label>Target Group</label>
                    <select value={selectedElement.sourceGroupId || currentGroupId} on:change={(e) => {
                      const oldGroupId = selectedElement.sourceGroupId;
                      const newGroupId = e.target.value;
                      selectedElement.sourceGroupId = newGroupId;
                      // Re-propagate to the new group
                      propagateNavToScope(selectedElement, 'group', 'group', oldGroupId);
                      cast = { ...cast };
                    }}>
                      {#each cast?.definition?.groups || [] as group}
                        <option value={group.id}>{group.name || 'Unnamed Group'}</option>
                      {/each}
                    </select>
                  </div>
                {/if}
                
                {#if selectedElement.scope !== 'slide'}
                  <p class="scope-hint warning">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    All changes sync to {selectedElement.scope === 'cast' ? 'all slides' : `all slides in "${cast?.definition?.groups?.find(g => g.id === selectedElement.sourceGroupId)?.name || 'this group'}"`}
                  </p>
                {/if}
              {/if}
            </div>

            <!-- Layout -->
            <div class="prop-group">
              <h4>Layout</h4>
              <div class="prop-row">
                <label>Direction</label>
                <select bind:value={selectedElement.layout} on:change={(e) => {
                  const itemCount = selectedElement.items?.length || 2;
                  const padding = selectedElement.style?.itemPadding || 12;
                  const gap = selectedElement.style?.itemGap || 8;
                  const fontSize = selectedElement.style?.fontSize || 16;
                  const iconSize = selectedElement.style?.iconSize || 18;
                  const containerPadding = selectedElement.style?.containerPadding || 8;
                  
                  if (e.target.value === 'vertical') {
                    const itemHeight = Math.max(fontSize, iconSize) + padding * 2;
                    selectedElement.size.width = 200;
                    selectedElement.size.height = (itemHeight * itemCount) + (gap * (itemCount - 1)) + containerPadding * 2;
                  } else {
                    const itemWidth = 110;
                    selectedElement.size.width = (itemWidth * itemCount) + (gap * (itemCount - 1)) + containerPadding * 2;
                    selectedElement.size.height = Math.max(fontSize, iconSize) + padding * 2 + containerPadding * 2;
                  }
                  cast = { ...cast };
                }}>
                  <option value="horizontal">Horizontal</option>
                  <option value="vertical">Vertical</option>
                </select>
              </div>
            </div>
            
            <!-- Container Styling -->
            <div class="prop-group">
              <h4>Container</h4>
              <div class="prop-row color-row">
                <label>Background</label>
                <input type="color" value={selectedElement.style?.containerBackground || '#000000'} on:input={(e) => { selectedElement.style.containerBackground = e.target.value; cast = { ...cast }; }} />
              </div>
              <div class="prop-row">
                <label>Opacity</label>
                <div class="slider-with-value">
                  <input type="range" min="0" max="1" step="0.05" 
                    value={selectedElement.style?.containerOpacity ?? 0.6} 
                    on:input={(e) => { selectedElement.style.containerOpacity = parseFloat(e.target.value); cast = { ...cast }; }}
                  />
                  <span class="slider-value">{Math.round((selectedElement.style?.containerOpacity ?? 0.6) * 100)}%</span>
                </div>
              </div>
              <div class="prop-row">
                <label>Blur</label>
                <div class="slider-with-value">
                  <input type="range" min="0" max="50" step="1" 
                  value={selectedElement.style?.containerBlur ?? 0} 
                  on:input={(e) => { selectedElement.style.containerBlur = parseInt(e.target.value) || 0; cast = { ...cast }; }}
                />
                  <span class="slider-value">{selectedElement.style?.containerBlur ?? 0}px</span>
                </div>
              </div>
              <div class="prop-row">
                <label>Radius</label>
                <div class="slider-with-value">
                  <input type="range" min="0" max="50" step="1" 
                  value={selectedElement.style?.containerRadius ?? 16} 
                  on:input={(e) => { selectedElement.style.containerRadius = parseInt(e.target.value) || 0; cast = { ...cast }; }}
                />
                  <span class="slider-value">{selectedElement.style?.containerRadius ?? 16}px</span>
                </div>
              </div>
              <div class="prop-row">
                <label>Padding</label>
                <div class="slider-with-value">
                  <input type="range" min="0" max="40" step="1" 
                  value={selectedElement.style?.containerPadding ?? 8} 
                  on:input={(e) => { selectedElement.style.containerPadding = parseInt(e.target.value) || 0; cast = { ...cast }; }}
                />
                  <span class="slider-value">{selectedElement.style?.containerPadding ?? 8}px</span>
                </div>
              </div>
            </div>

            <!-- Item Styling -->
            <div class="prop-group">
              <h4>Items</h4>
              <div class="prop-row color-row">
                <label>Background</label>
                <input type="color" value={selectedElement.style?.itemBackgroundColor || '#ffffff'} on:input={(e) => { selectedElement.style.itemBackgroundColor = e.target.value; cast = { ...cast }; }} />
              </div>
              <div class="prop-row">
                <label>BG Opacity</label>
                <div class="slider-with-value">
                  <input type="range" min="0" max="1" step="0.05" 
                    value={selectedElement.style?.itemBackgroundOpacity ?? 0} 
                    on:input={(e) => { selectedElement.style.itemBackgroundOpacity = parseFloat(e.target.value); cast = { ...cast }; }}
                  />
                  <span class="slider-value">{Math.round((selectedElement.style?.itemBackgroundOpacity ?? 0) * 100)}%</span>
                </div>
              </div>
              <div class="prop-row color-row">
                <label>Text</label>
                <input type="color" value={selectedElement.style?.itemColor || '#ffffff'} on:input={(e) => { selectedElement.style.itemColor = e.target.value; cast = { ...cast }; }} />
              </div>
              <div class="prop-row">
                <label>Font Size</label>
                <div class="slider-with-value">
                  <input type="range" min="10" max="48" step="1" 
                      value={selectedElement.style?.fontSize ?? 16} 
                      on:input={(e) => { selectedElement.style.fontSize = parseInt(e.target.value) || 16; cast = { ...cast }; }}
                    />
                  <span class="slider-value">{selectedElement.style?.fontSize ?? 16}px</span>
                  </div>
                </div>
              <div class="prop-row">
                <label>Icon Size</label>
                <div class="slider-with-value">
                  <input type="range" min="12" max="64" step="1" 
                      value={selectedElement.style?.iconSize ?? 18} 
                      on:input={(e) => { selectedElement.style.iconSize = parseInt(e.target.value) || 18; cast = { ...cast }; }}
                    />
                  <span class="slider-value">{selectedElement.style?.iconSize ?? 18}px</span>
                  </div>
                </div>
              <div class="prop-row">
                  <label>Padding</label>
                <div class="slider-with-value">
                  <input type="range" min="0" max="40" step="1" 
                      value={selectedElement.style?.itemPadding ?? 12} 
                      on:input={(e) => { selectedElement.style.itemPadding = parseInt(e.target.value) || 0; cast = { ...cast }; }}
                    />
                  <span class="slider-value">{selectedElement.style?.itemPadding ?? 12}px</span>
                  </div>
                </div>
              <div class="prop-row">
                  <label>Gap</label>
                <div class="slider-with-value">
                  <input type="range" min="0" max="50" step="1" 
                      value={selectedElement.style?.itemGap ?? 4} 
                      on:input={(e) => { selectedElement.style.itemGap = parseInt(e.target.value) || 0; cast = { ...cast }; }}
                    />
                  <span class="slider-value">{selectedElement.style?.itemGap ?? 4}px</span>
                  </div>
                </div>
              <div class="prop-row">
                  <label>Radius</label>
                <div class="slider-with-value">
                  <input type="range" min="0" max="50" step="1" 
                      value={selectedElement.style?.itemBorderRadius ?? 8} 
                      on:input={(e) => { selectedElement.style.itemBorderRadius = parseInt(e.target.value) || 0; cast = { ...cast }; }}
                    />
                  <span class="slider-value">{selectedElement.style?.itemBorderRadius ?? 8}px</span>
                  </div>
                </div>
              <div class="prop-row">
                  <label>Icon Pos</label>
                  <select value={selectedElement.style?.iconPosition || 'left'} on:change={(e) => { selectedElement.style.iconPosition = e.target.value; cast = { ...cast }; }}>
                    <option value="left">Left</option>
                    <option value="right">Right</option>
                    <option value="top">Top</option>
                    <option value="bottom">Bottom</option>
                    <option value="only">Icon Only</option>
                  </select>
              </div>
            </div>
            
            <!-- Active State -->
            <div class="prop-group">
              <h4>Active State</h4>
              <p class="prop-hint">Auto-highlights current slide/group</p>
              <div class="prop-row color-row">
                <label>Background</label>
                <input type="color" value={selectedElement.style?.activeBackgroundColor || '#6366f1'} on:input={(e) => { selectedElement.style.activeBackgroundColor = e.target.value; cast = { ...cast }; }} />
              </div>
              <div class="prop-row">
                <label>BG Opacity</label>
                <div class="slider-with-value">
                  <input type="range" min="0" max="1" step="0.05" 
                    value={selectedElement.style?.activeBackgroundOpacity ?? 0.9} 
                    on:input={(e) => { selectedElement.style.activeBackgroundOpacity = parseFloat(e.target.value); cast = { ...cast }; }}
                  />
                  <span class="slider-value">{Math.round((selectedElement.style?.activeBackgroundOpacity ?? 0.9) * 100)}%</span>
                </div>
              </div>
              <div class="prop-row color-row">
                <label>Text</label>
                <input type="color" value={selectedElement.style?.activeTextColor || '#ffffff'} on:input={(e) => { selectedElement.style.activeTextColor = e.target.value; cast = { ...cast }; }} />
              </div>
              <div class="prop-row">
                <label>Indicator</label>
                <select value={selectedElement.style?.activeIndicator || 'background'} on:change={(e) => { selectedElement.style.activeIndicator = e.target.value; cast = { ...cast }; }}>
                  <option value="background">Background</option>
                  <option value="underline">Underline</option>
                  <option value="border">Border</option>
                  <option value="dot">Dot</option>
                  <option value="glow">Glow</option>
                </select>
              </div>
            </div>

            <!-- Hover Effects -->
            <div class="prop-group">
              <h4>Hover Effects</h4>
              <div class="prop-row color-row">
                <label>Background</label>
                <input type="color" value={selectedElement.style?.hoverBackgroundColor || '#ffffff'} on:input={(e) => { selectedElement.style.hoverBackgroundColor = e.target.value; cast = { ...cast }; }} />
              </div>
              <div class="prop-row">
                <label>BG Opacity</label>
                <div class="slider-with-value">
                  <input type="range" min="0" max="1" step="0.05" 
                    value={selectedElement.style?.hoverBackgroundOpacity ?? 0.15} 
                    on:input={(e) => { selectedElement.style.hoverBackgroundOpacity = parseFloat(e.target.value); cast = { ...cast }; }}
                  />
                  <span class="slider-value">{Math.round((selectedElement.style?.hoverBackgroundOpacity ?? 0.15) * 100)}%</span>
                </div>
              </div>
              <div class="prop-row">
                <label>Scale</label>
                <div class="slider-with-value">
                  <input type="range" min="1" max="1.3" step="0.01" 
                    value={selectedElement.style?.hoverScale ?? 1.02} 
                    on:input={(e) => { selectedElement.style.hoverScale = parseFloat(e.target.value); cast = { ...cast }; }}
                  />
                  <span class="slider-value">{Math.round((selectedElement.style?.hoverScale ?? 1.02) * 100)}%</span>
                </div>
              </div>
            </div>
            
            <div class="prop-group nav-items-group">
              <h4>Menu Items</h4>
              {#each selectedElement.items || [] as item, i}
                <div class="nav-menu-item">
                  <div class="nav-menu-item-main">
                    <button 
                      class="nav-icon-btn" 
                      on:click={() => { showNavIconPicker = true; navIconPickerItemIndex = i; }}
                      title="Choose Icon"
                    >
                      {#if item.iconClass}
                        <i class="{item.iconClass}"></i>
                      {:else if item.iconSvg}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">{@html item.iconSvg}</svg>
                      {:else if item.icon}
                        <span>{item.icon}</span>
                      {:else}
                        <i class="fa-solid fa-circle-dot"></i>
                      {/if}
                    </button>
                    <input type="text" class="nav-label-input" bind:value={item.label} placeholder="Label" on:input={() => cast = cast} />
                    <button class="nav-delete-btn" on:click={() => { 
                      selectedElement.items.splice(i, 1);
                      // Auto-resize nav after removing item
                      const itemCount = selectedElement.items.length || 1;
                      const padding = selectedElement.style?.itemPadding || 16;
                      const gap = selectedElement.style?.itemGap || 12;
                      const fontSize = selectedElement.style?.fontSize || 18;
                      const iconSize = selectedElement.style?.iconSize || 20;
                      
                      if (selectedElement.layout === 'vertical') {
                        const itemHeight = Math.max(fontSize, iconSize) + padding * 2;
                        selectedElement.size.height = (itemHeight * itemCount) + (gap * (itemCount - 1)) + padding;
                      } else {
                        const itemWidth = 120;
                        selectedElement.size.width = (itemWidth * itemCount) + (gap * (itemCount - 1)) + padding;
                      }
                      cast = { ...cast }; 
                    }} title="Remove Item">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                  </div>
                  <div class="nav-menu-item-settings">
                    <select class="nav-action-select" bind:value={item.action.type} on:change={() => cast = cast}>
                      <option value="group">→ Group</option>
                      <option value="slide">→ Slide</option>
                      <option value="webhook">⚡ Webhook</option>
                      <option value="url">🔗 URL</option>
                    </select>
                    {#if item.action.type === 'group'}
                      <select class="nav-target-select" bind:value={item.action.group_id} on:change={() => cast = cast}>
                        <option value="">Select...</option>
                        {#each cast?.definition?.groups || [] as group}
                          <option value={group.id}>{group.name}</option>
                        {/each}
                      </select>
                    {:else if item.action.type === 'slide'}
                      <select class="nav-target-select" bind:value={item.action.group_id} on:change={() => cast = cast}>
                        {#each cast?.definition?.groups || [] as group}
                          <option value={group.id}>{group.name}</option>
                        {/each}
                      </select>
                      <select class="nav-target-select" bind:value={item.action.slide_index} on:change={() => cast = cast}>
                        <option value="">Slide...</option>
                        {#each (cast?.definition?.groups?.find(g => g.id === item.action.group_id)?.slides || currentSlides) as slide, slideIndex}
                          <option value={slideIndex}>{slide.name || `Slide ${slideIndex + 1}`}</option>
                        {/each}
                      </select>
                    {:else if item.action.type === 'webhook'}
                      <input type="url" class="nav-url-input" bind:value={item.action.webhook_url} placeholder="https://webhook..." on:input={() => cast = cast} />
                      <select class="nav-method-select" bind:value={item.action.webhook_method} on:change={() => cast = cast}>
                        <option value="POST">POST</option>
                        <option value="GET">GET</option>
                      </select>
                    {:else if item.action.type === 'url'}
                      <input type="url" class="nav-url-input full" bind:value={item.action.url} placeholder="https://..." on:input={() => cast = cast} />
                    {/if}
                  </div>
                </div>
              {/each}
              <button class="nav-add-btn" on:click={() => { 
                if (!selectedElement.items) selectedElement.items = [];
                selectedElement.items.push({ 
                  id: generateId(), 
                  label: 'New Item', 
                  iconClass: 'fa-solid fa-circle-dot', 
                  action: { type: 'slide', slide_index: 0, group_id: currentGroupId } 
                });
                // Auto-resize nav to fit new item
                const itemCount = selectedElement.items.length;
                const padding = selectedElement.style?.itemPadding || 16;
                const gap = selectedElement.style?.itemGap || 12;
                const fontSize = selectedElement.style?.fontSize || 18;
                const iconSize = selectedElement.style?.iconSize || 20;
                
                if (selectedElement.layout === 'vertical') {
                  const itemHeight = Math.max(fontSize, iconSize) + padding * 2;
                  selectedElement.size.height = (itemHeight * itemCount) + (gap * (itemCount - 1)) + padding;
                } else {
                  const itemWidth = 120;
                  selectedElement.size.width = (itemWidth * itemCount) + (gap * (itemCount - 1)) + padding;
                }
                cast = { ...cast }; 
              }}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Item
              </button>
            </div>
          {/if}

          <!-- Ping properties -->
          {#if selectedElement.type === 'ping'}
            <div class="prop-group">
              <h4>Ping Button</h4>
              <div class="prop-row">
                <label>Label</label>
                <input type="text" bind:value={selectedElement.label} on:input={() => cast = cast} />
              </div>
              <div class="prop-row">
                <label>Icon</label>
                <input type="text" bind:value={selectedElement.icon} on:input={() => cast = cast} />
              </div>
              <div class="prop-row">
                <label>Ping ID</label>
                <input type="text" bind:value={selectedElement.ping_name} on:input={() => cast = cast} />
              </div>
              <div class="prop-row">
                <label>Color</label>
                <input type="color" bind:value={selectedElement.style.background} on:input={() => cast = cast} />
              </div>
              <div class="prop-row">
                <label>Opacity</label>
                <input type="range" min="0" max="1" step="0.1" bind:value={selectedElement.style.opacity} on:input={() => cast = cast} />
              </div>
            </div>
          {/if}

          <!-- QR Code properties (simplified - full config in floating window) -->
          {#if selectedElement.type === 'qrcode'}
            <!-- Info Card -->
            <div class="prop-group">
              <div class="widget-info-card" on:click={() => openQRConfig(selectedElement)}>
                <span class="widget-icon">📱</span>
                <div class="widget-meta">
                  <span class="widget-name">QR Code</span>
                  <span class="widget-type">{selectedElement.qrType === 'wifi' ? 'WiFi Network' : selectedElement.qrType === 'text' ? 'Plain Text' : 'URL Link'}</span>
                </div>
                <button class="widget-config-btn" on:click|stopPropagation={() => openQRConfig(selectedElement)} title="Edit QR Code">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.08-.47-.12-.61l-2.03-1.58z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </div>
            </div>
            
            <!-- Layer Properties -->
            <div class="prop-group">
              <h4>Layer</h4>
              <div class="prop-row">
                <label>Opacity</label>
                <div class="slider-with-value">
                  <input 
                    type="range" 
                    min="0" 
                    max="1" 
                    step="0.1" 
                    bind:value={selectedElement.style.opacity} 
                    on:input={() => cast = cast}
                  />
                  <span class="slider-value">{Math.round((selectedElement.style.opacity ?? 1) * 100)}%</span>
                </div>
              </div>
            </div>
          {/if}

          <!-- Video properties -->
          {#if selectedElement.type === 'video'}
            <div class="prop-group">
              <h4>Video</h4>
              <button class="btn btn-secondary btn-sm" on:click={() => showMediaModal = true}>Change Video</button>
              <div class="prop-row">
                <label>Loop</label>
                <label class="toggle-switch">
                <input type="checkbox" bind:checked={selectedElement.playback.loop} on:change={() => cast = cast} />
                  <span class="toggle-slider"></span>
                </label>
              </div>
              <div class="prop-row">
                <label>Muted</label>
                <label class="toggle-switch">
                <input type="checkbox" bind:checked={selectedElement.playback.muted} on:change={() => cast = cast} />
                  <span class="toggle-slider"></span>
                </label>
              </div>
              <div class="prop-row">
                <label>Autoplay</label>
                <label class="toggle-switch">
                <input type="checkbox" bind:checked={selectedElement.playback.autoplay} on:change={() => cast = cast} />
                  <span class="toggle-slider"></span>
                </label>
              </div>
              <div class="prop-row">
                <label>Fit</label>
                <select bind:value={selectedElement.style.objectFit} on:change={() => cast = cast}>
                  <option value="cover">Cover</option>
                  <option value="contain">Contain</option>
                  <option value="fill">Fill</option>
                </select>
              </div>
              <div class="prop-row">
                <label>Opacity</label>
                <input type="range" min="0" max="1" step="0.1" bind:value={selectedElement.style.opacity} on:input={() => cast = cast} />
              </div>
            </div>
          {/if}

        </div>
      {:else}
        <div class="no-selection">
              <p>Select an element to edit</p>
        </div>
      {/if}
        </div>
        {/if}
      </div>
    </aside>
  </div>

  <!-- Toolbar -->
  <footer class="studio-toolbar">
    <button class="tool-btn" on:click={() => showMediaModal = true} title="Image">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
      <span>Image</span>
    </button>
    <button class="tool-btn" on:click={() => addElement('text')} title="Text">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M5 4v3h5.5v12h3V7H19V4H5z"/></svg>
      <span>Text</span>
    </button>
    <button class="tool-btn" on:click={() => addElement('shape', { shape: 'rectangle' })} title="Shape">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h18v18H3V3z"/></svg>
      <span>Shape</span>
    </button>
    <button class="tool-btn" on:click={() => addElement('nav')} title="Navigation">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
      <span>Nav</span>
    </button>
    <button class="tool-btn" on:click={() => addElement('ping')} title="Ping Button">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/></svg>
      <span>Ping</span>
    </button>
    <button class="tool-btn" on:click={() => addElement('qrcode')} title="QR Code">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 11h8V3H3v8zm2-6h4v4H5V5zm8-2v8h8V3h-8zm6 6h-4V5h4v4zM3 21h8v-8H3v8zm2-6h4v4H5v-4zm13 0h1v1h-1zm-3-1h2v2h-2zm-1 2h1v4h-4v-2h1v-1h2zm4-1h2v4h-1v-3h-1zm-3 4h1v1h-1zm2 0h1v1h-1z"/></svg>
      <span>QR</span>
    </button>
    <button class="tool-btn" on:click={() => showWidgetModal = true} title="Widget">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h8v8H3V3zm2 2v4h4V5H5zm8-2h8v8h-8V3zm2 2v4h4V5h-4zM3 13h8v8H3v-8zm2 2v4h4v-4H5zm8-2h8v8h-8v-8zm2 2v4h4v-4h-4z"/></svg>
      <span>Widget</span>
    </button>
    <div class="toolbar-divider"></div>
    <span class="toolbar-hint">{modKey}+Z undo • {modKey}+Y redo • {modKey}+S save • Del delete</span>
    
    <!-- Zoom Controls with Tool Selection -->
    <div class="toolbar-zoom">
      <button 
        class="zoom-btn tool-btn" 
        class:active={activeTool === 'pointer'} 
        on:click={() => activeTool = 'pointer'} 
        title="Selection Tool (V)"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M4 4l16 8-7 2-2 7z"/></svg>
      </button>
      <button 
        class="zoom-btn tool-btn" 
        class:active={activeTool === 'hand'} 
        on:click={() => activeTool = 'hand'} 
        title="Hand Tool (H) - Pan canvas"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M18 12V8a2 2 0 00-2-2 2 2 0 00-2 2V4a2 2 0 00-2-2 2 2 0 00-2 2v6.5L8.5 9A2.12 2.12 0 006 9.25a2 2 0 00-.12 2.91L10.5 18H18a2 2 0 002-2v-4a2 2 0 00-2-2z"/></svg>
      </button>
      <span class="toolbar-separator"></span>
      <button class="zoom-btn" on:click={zoomOut} title="Zoom Out">−</button>
      <span class="zoom-level">{Math.round(canvasZoom * 100)}%</span>
      <button class="zoom-btn" on:click={zoomIn} title="Zoom In">+</button>
      <button class="zoom-btn" on:click={zoomFit} title="Fit to Screen">
        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M3 3h6v2H5v4H3V3zm12 0h6v6h-2V5h-4V3zM3 15h2v4h4v2H3v-6zm16 0h2v6h-6v-2h4v-4z"/></svg>
      </button>
    </div>
  </footer>
</div>
{/if}

<!-- Media Modal -->
<!-- Media Modal -->
<MediaModal 
  bind:show={showMediaModal}
  {mediaLibrary}
  {uploadingMedia}
  on:close={() => showMediaModal = false}
  on:select={(e) => selectMedia(e.detail.media)}
  on:upload={(e) => handleMediaUpload(e.detail.files)}
  on:importUrl={(e) => importFromUrl(e.detail.url)}
/>

<!-- Widget Modal -->
<WidgetModal 
  bind:show={showWidgetModal}
  {availableWidgets}
  {widgetCategories}
  on:close={() => showWidgetModal = false}
  on:select={(e) => { addElement('widget', { widgetUuid: e.detail.widget.uuid }); }}
/>

<!-- Variables Modal -->
<VariablesModal 
  bind:show={showVariablesModal}
  {cast}
  on:close={() => showVariablesModal = false}
  on:update={() => cast = { ...cast }}
/>

<!-- Save as Template Modal -->
<SaveAsTemplateModal 
  bind:show={showSaveAsTemplateModal}
  defaultName={cast?.name || 'My Template'}
  saving={savingTemplate}
  on:close={() => showSaveAsTemplateModal = false}
  on:save={(e) => saveAsTemplate(e.detail.name, e.detail.description)}
/>

<!-- Keyboard Shortcuts Modal -->
<KeyboardShortcutsModal 
  bind:show={showKeyboardShortcutsModal}
  {modKey}
  on:close={() => showKeyboardShortcutsModal = false}
/>

<!-- Canvas Size Modal -->
{#if showCanvasSizeModal}
  <div class="modal-overlay" on:click={() => showCanvasSizeModal = false}>
    <div class="modal modal-sm" on:click|stopPropagation>
      <div class="modal-header"><h2>Canvas Size</h2><button class="close-btn" on:click={() => showCanvasSizeModal = false}>×</button></div>
      <div class="modal-body">
        <p class="help-text">Slidecast uses a fixed 16:9 aspect ratio optimized for modern displays and TVs.</p>
        <div class="canvas-size-display"><div class="size-preview"><div class="size-box"><span class="size-value">1920 × 1080</span><span class="size-label">Full HD (16:9)</span></div></div></div>
        <p class="info-text" style="margin-top: 1rem; font-size: 0.75rem; color: rgb(var(--color-text-secondary));"><i class="fa-solid fa-circle-info" style="margin-right: 0.25rem;"></i>Support for custom resolutions coming soon.</p>
      </div>
      <div class="modal-footer"><button class="btn btn-primary" on:click={() => showCanvasSizeModal = false}>Done</button></div>
    </div>
  </div>
{/if}

<!-- Add Group Modal -->
<AddGroupModal 
  bind:show={showAddGroupModal}
  on:close={() => showAddGroupModal = false}
  on:create={(e) => addGroup(e.detail.name)}
/>

<!-- Slide Settings Modal -->
<SlideSettingsModal
  show={showSlideSettingsModal && editingSlideIndex !== null}
  slide={currentSlides[editingSlideIndex]}
  slideIndex={editingSlideIndex}
  currentGroup={getCurrentGroup()}
  on:close={() => { showSlideSettingsModal = false; editingSlideIndex = null; }}
  on:update={() => { cast = { ...cast }; }}
  on:history={(e) => pushHistory(e.detail)}
  on:updateBackgroundColor={(e) => updateSlideBackgroundColor(e.detail.slide, e.detail.color)}
  on:resetBackground={(e) => {
    e.detail.slide._hasCustomBackground = false;
    e.detail.slide.backgroundColor = null;
    updateSlideBackgroundColor(e.detail.slide, e.detail.defaultColor);
  }}
/>

<!-- Group Settings Modal -->
<GroupSettingsModal
  show={showGroupSettingsModal}
  currentGroup={getCurrentGroup()}
  {cast}
  on:close={() => showGroupSettingsModal = false}
  on:update={() => { cast = { ...cast }; }}
  on:history={(e) => pushHistory(e.detail)}
  on:updateDefaultBackgrounds={(e) => updateGroupDefaultBackgrounds(e.detail.group, e.detail.color)}
/>

<!-- Paste Slide Modal -->
{#if showPasteSlideModal && slideClipboard}
  <div class="modal-overlay" on:click={() => showPasteSlideModal = false}>
    <div class="modal modal-sm" on:click|stopPropagation>
      <div class="modal-header">
        <h2>Paste Slide</h2>
        <button class="close-btn" on:click={() => showPasteSlideModal = false}>×</button>
      </div>
      <div class="modal-body">
        <p>Paste <strong>"{slideClipboard.slide.name}"</strong> to which group?</p>
        <div class="paste-group-list">
          {#each cast?.definition?.groups || [] as group}
            <button 
              class="paste-group-option" 
              class:current={group.id === currentGroupId}
              on:click={() => pasteSlideToGroup(group.id)}
            >
              {#if group.id === 'home'}<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>{/if}
              {group.name || 'Home'}
              {#if group.id === currentGroupId}<span class="current-badge">Current</span>{/if}
            </button>
          {/each}
        </div>
        {#if clipboardOperation === 'cut'}
          <p class="help-text"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 4px;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> This is a cut operation. The slide will be moved from "{cast?.definition?.groups?.find(g => g.id === slideClipboard.sourceGroupId)?.name || 'Home'}".</p>
        {/if}
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" on:click={() => { showPasteSlideModal = false; if (clipboardOperation === 'cut') { slideClipboard = null; clipboardOperation = null; } }}>Cancel</button>
      </div>
    </div>
  </div>
{/if}

<!-- Unsaved Changes Confirmation Modal -->
<UnsavedChangesModal 
  bind:show={showUnsavedChangesModal}
  on:cancel={cancelNavigation}
  on:discard={confirmNavigateAway}
  on:save={saveAndNavigate}
/>

<!-- Delete Layer Confirmation Modal -->
<DeleteConfirmModal 
  bind:show={showDeleteLayerModal}
  type="layer"
  on:close={() => { showDeleteLayerModal = false; pendingDeleteLayerId = null; }}
  on:confirm={executeDeleteLayer}
/>

<!-- Delete Slide Confirmation Modal -->
<DeleteConfirmModal 
  bind:show={showDeleteSlideModal}
  type="slide"
  on:close={() => { showDeleteSlideModal = false; pendingDeleteSlideIndex = null; }}
  on:confirm={executeDeleteSlide}
/>

<!-- Delete Group Confirmation Modal -->
{#if showDeleteGroupModal}
  {@const groupToDelete = cast?.definition?.groups?.find(g => g.id === pendingDeleteGroupId)}
  <DeleteConfirmModal 
    show={true}
    type="group"
    itemName={groupToDelete?.name || 'Unknown'}
    slideCount={groupToDelete?.slides?.length || 0}
    on:close={() => { showDeleteGroupModal = false; pendingDeleteGroupId = null; }}
    on:confirm={executeDeleteGroup}
  />
{/if}

<!-- Nav Icon Picker Modal - Font Awesome -->
{#if showNavIconPicker && selectedElement?.type === 'nav'}
  <div class="modal-overlay" on:click={() => { showNavIconPicker = false; navIconPickerItemIndex = null; iconSearchQuery = ''; activeIconCategory = 'all'; }}>
    <div class="modal modal-icon-picker modal-lg" on:click|stopPropagation>
      <div class="modal-header">
        <span class="modal-icon"><i class="fa-solid fa-icons"></i></span>
        <h2>Choose Icon</h2>
        <span class="icon-count">{allIcons.length} icons</span>
        <button class="modal-close" on:click={() => { showNavIconPicker = false; navIconPickerItemIndex = null; iconSearchQuery = ''; activeIconCategory = 'all'; }}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      
      <div class="icon-picker-search">
        <i class="fa-solid fa-magnifying-glass search-icon"></i>
        <input 
          type="text" 
          bind:value={iconSearchQuery}
          placeholder="Search {allIcons.length} icons..."
          class="search-input"
        />
      </div>
      
      <div class="icon-picker-categories">
        <button 
          class="category-btn" 
          class:active={activeIconCategory === 'all'}
          on:click={() => activeIconCategory = 'all'}
        >All</button>
        {#each iconCategories as category}
          <button 
            class="category-btn"
            class:active={activeIconCategory === category.name}
            on:click={() => activeIconCategory = category.name}
          >{category.name}</button>
        {/each}
      </div>
      
      <div class="modal-body icon-picker-body">
        <div class="icon-grid fa-icon-grid">
          {#each filteredNavIcons as navIcon}
            <button 
              class="icon-option fa-icon-option" 
              class:selected={selectedElement.items[navIconPickerItemIndex]?.iconClass === navIcon.class}
              on:click={() => {
                if (selectedElement.items && selectedElement.items[navIconPickerItemIndex]) {
                  selectedElement.items[navIconPickerItemIndex].iconClass = navIcon.class;
                  selectedElement.items[navIconPickerItemIndex].iconSvg = null;
                  selectedElement.items[navIconPickerItemIndex].icon = null;
                  cast = { ...cast };
                }
                showNavIconPicker = false;
                navIconPickerItemIndex = null;
                iconSearchQuery = '';
                activeIconCategory = 'all';
              }}
              title={navIcon.name}
            >
              <i class={navIcon.class}></i>
              <span class="icon-name">{navIcon.name}</span>
            </button>
          {/each}
          
          {#if filteredNavIcons.length === 0}
            <div class="no-results">
              <i class="fa-solid fa-magnifying-glass"></i>
              <p>No icons found for "{iconSearchQuery}"</p>
            </div>
          {/if}
        </div>
        
        <div class="custom-icon-section">
          <h4>Or use custom emoji/text:</h4>
          <div class="custom-icon-input-row">
            <input 
              type="text" 
              placeholder="Enter emoji or text..." 
              class="custom-icon-input"
              on:keydown={(e) => {
                if (e.key === 'Enter' && e.target.value) {
                  if (selectedElement.items && selectedElement.items[navIconPickerItemIndex]) {
                    selectedElement.items[navIconPickerItemIndex].icon = e.target.value;
                    selectedElement.items[navIconPickerItemIndex].iconClass = null;
                    selectedElement.items[navIconPickerItemIndex].iconSvg = null;
                    cast = { ...cast };
                  }
                  showNavIconPicker = false;
                  navIconPickerItemIndex = null;
                  iconSearchQuery = '';
                  activeIconCategory = 'all';
                }
              }}
            />
            <button 
              class="btn btn-primary btn-sm"
              on:click={(e) => {
                const input = e.target.parentElement.querySelector('input');
                if (input?.value && selectedElement.items && selectedElement.items[navIconPickerItemIndex]) {
                  selectedElement.items[navIconPickerItemIndex].icon = input.value;
                  selectedElement.items[navIconPickerItemIndex].iconClass = null;
                  selectedElement.items[navIconPickerItemIndex].iconSvg = null;
                  cast = { ...cast };
                  showNavIconPicker = false;
                  navIconPickerItemIndex = null;
                  iconSearchQuery = '';
                  activeIconCategory = 'all';
                }
              }}
            >Apply</button>
          </div>
        </div>
      </div>
    </div>
  </div>
{/if}

<!-- Widget Configuration Floating Window -->
{#if showWidgetConfigModal && widgetConfigElement}
  <WidgetConfigWindow 
    element={widgetConfigElement}
    widget={availableWidgets.find(w => w.uuid === widgetConfigElement.widgetUuid)}
    bind:position={widgetConfigPos}
    isRunning={widgetConfigElement._isRunning}
    on:close={closeWidgetConfig}
    on:update={() => { cast = { ...cast }; }}
    on:refresh={() => refreshWidget(widgetConfigElement)}
    on:autoRun={() => refreshWidget(widgetConfigElement)}
  />
{/if}



<!-- Text Configuration Floating Window -->
{#if showTextConfigModal && textConfigElement}
  <TextConfigWindow 
    element={textConfigElement}
    bind:position={textConfigPos}
    on:close={closeTextConfig}
    on:change={(e) => trackPropertyChange(e.detail.property)}
    on:update={() => { cast = { ...cast }; }}
    on:history={(e) => pushHistory(e.detail.action)}
  />
{/if}


<!-- Nav Configuration Floating Window -->
{#if showNavConfigModal && navConfigElement}
  <NavConfigWindow 
    element={navConfigElement}
    bind:position={navConfigPos}
    {cast}
    {currentGroupId}
    {iconCategories}
    {allIcons}
    on:close={closeNavConfig}
    on:sync={() => { cast = { ...cast }; syncNavChanges(navConfigElement); }}
    on:goToSource={(e) => goToNavSource(e.detail.element)}
  />
{/if}
<!-- QR Code Configuration Floating Window -->
{#if showQRConfigModal && qrConfigElement}
  <QRConfigWindow 
    element={qrConfigElement}
    bind:position={qrConfigPos}
    on:close={closeQRConfig}
    on:update={updateQRData}
  />
{/if}

<style>
  /* Styles loaded dynamically from /api/extensions/slidecast/static/studio.css */
</style>
